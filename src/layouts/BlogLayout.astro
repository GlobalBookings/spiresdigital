---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getArticleJourney } from '../data/articleJourneys';

interface Props {
  title: string;
  description?: string;
  date?: string;
  category?: string;
  image?: string;
  readTime?: string;
  slug?: string;
  noindex?: boolean;
}

const { title, description, date, category, image, readTime, slug = '', noindex = false } = Astro.props;
const journey = getArticleJourney(slug, category);
const formattedDate = date ? new Date(`${date}T12:00:00Z`).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
const categoryAnchor: Record<string, string> = { 'PPC': 'ppc', 'Meta Ads': 'meta-ads', 'Affiliate Marketing': 'affiliate-marketing', 'Shopify': 'shopify-ecommerce', 'E-Commerce': 'shopify-ecommerce', 'Strategy': 'strategy-analytics', 'Analytics': 'strategy-analytics', 'SEO': 'strategy-analytics' };
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date,
  dateModified: date,
  image: image ? new URL(image, 'https://spiresdigital.com').href : 'https://spiresdigital.com/images/og-default.png',
  author: { '@type': 'Person', name: 'Jack', url: 'https://spiresdigital.com/about/' },
  publisher: { '@id': 'https://spiresdigital.com/#organisation' },
  mainEntityOfPage: new URL(Astro.url.pathname, 'https://spiresdigital.com').href,
};
---

<BaseLayout title={title} description={description} image={image} lastUpdated={date} noindex={noindex} schema={schema}>
  <div class="blog-post">
    <Breadcrumbs items={[{ label: 'Insights', href: '/blog' }, { label: title }]} />
    <article class="blog-article container">
      <header class="blog-header">
        {category && <a class="badge" href={`/blog/#${categoryAnchor[category] || ''}`}>{category}</a>}
        <h1>{title}</h1>
        <p class="standfirst">{description}</p>
        <div class="byline">
          <span class="author-mark" aria-hidden="true">J</span>
          <div><strong>Written by Jack, founder of Spires Digital</strong><span>{formattedDate}{readTime ? ` · ${readTime}` : ''}</span></div>
        </div>
      </header>

      {image && <div class="blog-hero-image"><img src={image} alt="" width="1200" height="630" loading="eager" referrerpolicy="no-referrer" /></div>}

      <div class="article-grid">
        <aside class="article-note"><strong>Editorial approach</strong><p>Guidance is based on hands-on marketing experience and the information available on the publication date. Platform features, costs and tax treatment can change; verify decisions in your own accounts and with a qualified adviser where relevant.</p><a href="/about">About the author →</a></aside>
        <div class="blog-content"><slot /></div>
      </div>
    </article>

    <section class="article-next"><div class="container"><div><span>{journey.eyebrow}</span><h2>{journey.title}</h2></div><div><a href={journey.primaryHref} class="btn btn-secondary" data-track={`article_next_${slug || 'generic'}_primary`}>{journey.primaryLabel}</a><a href={journey.secondaryHref} class="btn btn-primary" data-track={`article_next_${slug || 'generic'}_secondary`}>{journey.secondaryLabel}</a></div></div></section>
  </div>
</BaseLayout>

<style>
  .blog-article { padding-top: 3rem; padding-bottom: 6rem; }
  .blog-header { max-width: 880px; margin-inline: auto; text-align: center; }
  .blog-header h1 { font-size: clamp(2.4rem,5.5vw,4.8rem); }
  .standfirst { max-width: 720px; margin: 1.2rem auto 0; color: var(--slate); font-size: clamp(1.05rem,2vw,1.25rem); }
  .byline { display: flex; width: fit-content; align-items: center; gap: .75rem; margin: 1.6rem auto 0; text-align: left; }
  .byline strong, .byline span { display: block; }
  .byline strong { color: var(--ink); font-size: .84rem; }
  .byline span { color: var(--muted); font-size: .78rem; }
  .author-mark { display: grid; width: 42px; height: 42px; place-items: center; border-radius: 50%; background: var(--ink); color: white; font-weight: 850; }
  .blog-hero-image { overflow: hidden; max-width: 980px; margin: 3rem auto; border-radius: var(--radius-lg); background: var(--line); }
  .blog-hero-image img { width: 100%; aspect-ratio: 1.9/1; object-fit: cover; }
  .article-grid { display: grid; grid-template-columns: 220px minmax(0,720px); justify-content: center; gap: clamp(2rem,6vw,5rem); margin-top: 3rem; align-items: start; }
  .article-note { position: sticky; top: 110px; padding: 1rem; border-top: 3px solid var(--violet); background: var(--violet-soft); font-size: .78rem; }
  .article-note strong { color: var(--ink); }
  .article-note p { margin: .5rem 0 .75rem; color: var(--slate); }
  .article-note a { color: var(--violet-dark); font-weight: 750; }
  .blog-content { min-width: 0; color: #273348; font-size: 1.04rem; line-height: 1.82; }
  .blog-content :global(h2) { margin: 2.8rem 0 1rem; font-size: clamp(1.65rem,3vw,2.25rem); }
  .blog-content :global(h3) { margin: 2rem 0 .75rem; font-size: 1.3rem; }
  .blog-content :global(p), .blog-content :global(ul), .blog-content :global(ol), .blog-content :global(table), .blog-content :global(details) { margin-bottom: 1.25rem; }
  .blog-content :global(ul), .blog-content :global(ol) { padding-left: 1.4rem; }
  .blog-content :global(li) { margin-bottom: .48rem; }
  .blog-content :global(a) { color: var(--violet-dark); text-decoration: underline; text-underline-offset: 3px; }
  .blog-content :global(table) { display: block; overflow-x: auto; width: 100%; border-collapse: collapse; }
  .blog-content :global(th), .blog-content :global(td) { min-width: 140px; padding: .75rem; border: 1px solid var(--line); text-align: left; }
  .blog-content :global(details) { padding: 1rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: white; }
  .blog-content :global(summary) { cursor: pointer; color: var(--ink); font-weight: 750; }
  .article-next { padding: 3rem 0; background: var(--ink); color: white; }
  .article-next .container { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .article-next span { color: #a8fff0; font-size: .75rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .article-next h2 { max-width: 630px; margin-top: .3rem; color: white; font-size: clamp(1.6rem,3vw,2.4rem); }
  .article-next .container > div:last-child { display: flex; flex-wrap: wrap; gap: .7rem; flex-shrink: 0; }
  @media (max-width: 900px) { .article-grid { grid-template-columns: 1fr; } .article-note { position: static; max-width: 720px; margin-inline: auto; } .blog-content { max-width: 720px; margin-inline: auto; } .article-next .container { align-items: flex-start; flex-direction: column; } }
</style>

---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  date?: string;
  category?: string;
  image?: string;
  readTime?: string;
}

const { title, description, date, category, image, readTime } = Astro.props;
const formattedDate = date ? new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
---

<BaseLayout title={title} description={description} image={image} lastUpdated={date}>
  <div class="blog-post">
    <Breadcrumbs items={[{ label: 'Blog', href: '/blog' }, { label: title }]} />

    <article class="blog-article container">
      <header class="blog-header">
        {category && <span class="badge">{category}</span>}
        <h1>{title}</h1>
        <div class="blog-meta">
          {formattedDate && <span>{formattedDate}</span>}
          {readTime && <span>{readTime}</span>}
        </div>
      </header>

      {image && (
        <div class="blog-hero-image">
          <img src={image} alt={title} width="1200" height="630" loading="eager" />
        </div>
      )}

      <div class="blog-content">
        <slot />
      </div>
    </article>

    <section class="cta-section">
      <div class="container">
        <h2>Ready to Grow Your Business?</h2>
        <p>Get a free, no-obligation audit of your current digital marketing performance.</p>
        <a href="/contact" class="btn btn-white btn-lg">Get Free Marketing Audit</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .blog-article { max-width: 800px; padding-top: 2rem; padding-bottom: 4rem; }
  .blog-header { margin-bottom: 2rem; }
  .blog-header h1 { margin-top: 0.5rem; font-size: clamp(1.8rem, 3.5vw, 2.6rem); }
  .blog-meta { display: flex; gap: 1.5rem; color: var(--color-text-light); font-size: 0.9rem; margin-top: 0.75rem; }
  .blog-hero-image { margin-bottom: 2rem; border-radius: var(--radius); overflow: hidden; }
  .blog-hero-image img { width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; }
  .blog-content { font-size: 1.05rem; line-height: 1.8; }
  .blog-content :global(h2) { font-size: 1.5rem; margin: 2.5rem 0 1rem; }
  .blog-content :global(h3) { font-size: 1.2rem; margin: 2rem 0 0.75rem; }
  .blog-content :global(p) { margin-bottom: 1.25rem; }
  .blog-content :global(ul), .blog-content :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .blog-content :global(li) { margin-bottom: 0.5rem; }
  .blog-content :global(a) { color: var(--color-accent); text-decoration: underline; }
  .blog-content :global(a:hover) { color: var(--color-accent-dark); }
  .blog-content :global(.tip-box) { background: rgba(79,70,229,0.05); border-left: 4px solid var(--color-accent); padding: 1.25rem 1.5rem; border-radius: 0 8px 8px 0; margin: 1.5rem 0; }
</style>

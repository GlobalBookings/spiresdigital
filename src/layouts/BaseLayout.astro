---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  lastUpdated?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Profit-focused ecommerce growth across paid media, SEO, CRO, retention, affiliate and analytics. Spires Digital works from Guernsey with brands across the UK and beyond.',
  image = '/images/og-default.png',
  canonicalUrl,
  lastUpdated,
  noindex = false,
  schema,
} = Astro.props;

const site = 'https://spiresdigital.com';
const cleanPath = Astro.url.pathname === '/' ? '/' : `${Astro.url.pathname.replace(/\/+$/, '')}/`;
const canonical = canonicalUrl ? new URL(canonicalUrl, site).href : new URL(cleanPath, site).href;
const absoluteImage = new URL(image, site).href;
const pageTitle = title === 'Home'
  ? 'Spires Digital — Profit-Focused Ecommerce Growth Agency'
  : `${title} | Spires Digital`;
// GA measurement IDs are public identifiers. The environment variable allows a
// future property change without a code edit; this production fallback ensures
// the current site is tagged even when the hosting environment has no value set.
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-B7840X8QFQ';
const organisationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site}/#organisation`,
  name: 'Spires Digital',
  url: site,
  logo: `${site}/logo.png`,
  email: 'jack@spiresdigital.com',
  description: 'Profit-focused ecommerce growth agency covering acquisition, conversion, retention and measurement.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Guernsey',
    addressRegion: 'Channel Islands',
    addressCountry: 'GG',
  },
  areaServed: ['Guernsey', 'United Kingdom', 'Europe'],
};
const schemas = [organisationSchema, ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" /></noscript>
    <link rel="alternate" type="text/plain" href="/llms.txt" title="Spires Digital information" />
    {lastUpdated && <meta property="article:modified_time" content={lastUpdated} />}
    <meta property="og:type" content={cleanPath.startsWith('/blog/') ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Spires Digital" />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <title>{pageTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(schemas)} />
  </head>
  <body data-page={cleanPath}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <CookieBanner measurementId={measurementId} />
    <script is:inline>
      const storageGet = key => {
        try { return sessionStorage.getItem(key); } catch { return null; }
      };
      const storageSet = (key, value) => {
        try { sessionStorage.setItem(key, value); } catch { /* Attribution must never block the page. */ }
      };
      const cleanValue = (value, maxLength = 180) => String(value || '').trim().slice(0, maxLength);
      const currentPath = window.location.pathname;
      const deriveInterest = path => {
        const parts = path.split('/').filter(Boolean);
        if (parts[0] === 'services' && parts[1]) return `service:${parts[1]}`;
        if (parts[0] === 'tools' && parts[1]) return `tool:${parts[1]}`;
        if (parts[0] === 'industries' && parts[1]) return `industry:${parts[1]}`;
        if (parts[0] === 'locations' && parts[1]) return `location:${parts[1]}`;
        if (parts[0] === 'blog' && parts[1]) return `article:${parts[1]}`;
        if (parts.length === 0) return 'homepage';
        return cleanValue(parts.join(':'), 100);
      };

      if (!storageGet('spires_landing_page')) {
        storageSet('spires_landing_page', currentPath);
        let referrerDomain = '';
        try { referrerDomain = document.referrer ? new URL(document.referrer).hostname : ''; } catch { referrerDomain = ''; }
        storageSet('spires_referrer_domain', referrerDomain || 'direct');
      }

      const params = new URLSearchParams(window.location.search);
      const onContactPage = currentPath.replace(/\/+$/, '') === '/contact';
      const journeySourcePage = onContactPage ? cleanValue(params.get('source_page') || currentPath) : currentPath;
      const journeyInterest = onContactPage ? cleanValue(params.get('interest') || deriveInterest(journeySourcePage), 100) : deriveInterest(currentPath);
      ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid'].forEach(key => {
        const value = params.get(key);
        if (value) storageSet(`spires_${key}`, cleanValue(value));
      });

      document.querySelectorAll('a[href]').forEach(element => {
        const rawHref = element.getAttribute('href');
        if (!rawHref) return;
        let destination;
        try { destination = new URL(rawHref, window.location.origin); } catch { return; }
        if (destination.origin !== window.location.origin || destination.pathname.replace(/\/+$/, '') !== '/contact') return;
        if (!destination.searchParams.has('source_page')) destination.searchParams.set('source_page', journeySourcePage);
        if (!destination.searchParams.has('interest')) destination.searchParams.set('interest', element.dataset.interest || journeyInterest);
        element.setAttribute('href', `${destination.pathname}${destination.search}${destination.hash}`);
      });

      window.trackSpiresEvent = (name, parameters = {}) => {
        if (typeof window.gtag !== 'function') return;
        window.gtag('event', name, parameters);
      };
      document.querySelectorAll('[data-track]').forEach(element => {
        element.addEventListener('click', () => {
          const href = element.getAttribute('href') || '';
          let destinationPath = '';
          try {
            const destinationUrl = new URL(href, window.location.origin);
            destinationPath = destinationUrl.origin === window.location.origin ? destinationUrl.pathname : `external:${destinationUrl.hostname || destinationUrl.protocol.replace(':', '')}`;
          } catch { destinationPath = 'unknown'; }
          window.trackSpiresEvent('cta_click', {
            cta_name: element.dataset.track,
            page_path: currentPath,
            destination_path: destinationPath,
            lead_interest: element.dataset.interest || deriveInterest(currentPath),
          });
        });
      });

      document.querySelectorAll('form[data-capture-attribution]').forEach(form => {
        const addHiddenField = (key, value) => {
          if (!value || form.querySelector(`input[name="${key}"]`)) return;
          const input = document.createElement('input');
          input.type = 'hidden'; input.name = key; input.value = cleanValue(value); form.appendChild(input);
        };
        ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid'].forEach(key => {
          const value = storageGet(`spires_${key}`);
          if (!value) return;
          addHiddenField(key, value);
        });
        let sameSiteReferrerPath = '';
        try {
          const referrerUrl = document.referrer ? new URL(document.referrer) : null;
          if (referrerUrl?.origin === window.location.origin) sameSiteReferrerPath = referrerUrl.pathname;
        } catch { sameSiteReferrerPath = ''; }
        const sourcePage = cleanValue(params.get('source_page') || sameSiteReferrerPath || '/contact/');
        const leadInterest = cleanValue(params.get('interest') || deriveInterest(sourcePage), 100);
        const landingPage = cleanValue(storageGet('spires_landing_page') || sourcePage);
        const referrerDomain = cleanValue(storageGet('spires_referrer_domain') || 'direct', 100);
        const acquisitionSource = cleanValue(storageGet('spires_utm_source') || referrerDomain, 100);
        addHiddenField('source_page', sourcePage);
        addHiddenField('landing_page', landingPage);
        addHiddenField('lead_interest', leadInterest);
        addHiddenField('referrer_domain', referrerDomain);
        addHiddenField('acquisition_source', acquisitionSource);
      });
    </script>
  </body>
</html>

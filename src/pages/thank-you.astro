---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Growth Review Requested" description="Your Spires Digital growth review request has been received." noindex>
  <section class="thank-you hero-dark"><div class="container-narrow"><span class="badge">Request received</span><h1>Thank you. The useful work starts with the context.</h1><p>We will review what you shared and reply within one working day. If timing matters, you can choose a call now.</p><div class="page-hero-actions"><a href="https://calendly.com/jack-spiresdigital/30min?back=1" class="btn btn-primary btn-lg btn-arrow" target="_blank" rel="noopener" data-track="thank_you_calendly">Book a 30-minute call</a><a href="/tools/ecommerce-profit-calculator" class="btn btn-outline btn-lg">Calculate your break-even ROAS</a></div></div></section>
  <section class="section surface"><div class="container-narrow"><div class="next-grid"><article><span>While you wait</span><h2>Bring the numbers that make the conversation useful.</h2><ul class="check-list"><li>Average order value and gross margin</li><li>Monthly store revenue and ad spend</li><li>Conversion and repeat-purchase rate</li><li>The growth target you are working towards</li></ul></article><article class="privacy-note"><h3>Keep access secure</h3><p>We will never ask you to send passwords by email. Account access should be granted through the platform’s own user or partner controls when required.</p></article></div></div></section>
</BaseLayout>
<script>
  let leadContext = null;
  try {
    leadContext = JSON.parse(sessionStorage.getItem('spires_pending_lead') || 'null');
    sessionStorage.removeItem('spires_pending_lead');
  } catch { leadContext = null; }
  if (leadContext) window.trackSpiresEvent?.('generate_lead', leadContext);
  window.trackSpiresEvent?.('lead_confirmation_view', leadContext || { lead_type: 'growth_review', confirmation_context: 'direct_view' });
</script>
<style>.thank-you { min-height: 640px; display: grid; align-items: center; }.thank-you .container-narrow { position: relative; z-index: 1; }.next-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 2rem; }.next-grid h2 { margin: 1rem 0 1.5rem; }.privacy-note { align-self: end; padding: 1.4rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--canvas); }.privacy-note p { margin-top: .7rem; color: var(--slate); }@media(max-width:700px){.next-grid{grid-template-columns:1fr}}</style>

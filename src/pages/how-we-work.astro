---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How Spires Digital approaches an ecommerce growth engagement',
  description: 'A practical view of the discovery, diagnosis, roadmap and optimisation process used by Spires Digital.',
  step: [
    { '@type': 'HowToStep', name: 'Fit and context', text: 'Understand the store, economics, goals, access and current constraint.' },
    { '@type': 'HowToStep', name: 'Diagnose the system', text: 'Review acquisition, conversion, retention and measurement together.' },
    { '@type': 'HowToStep', name: 'Set the roadmap', text: 'Prioritise work by evidence, likely impact, effort and dependency.' },
    { '@type': 'HowToStep', name: 'Run and learn', text: 'Implement, measure and document the next best decision.' },
  ],
};

const stages = [
  { number: '01', label: 'Fit first', title: 'Context before recommendations', copy: 'We start with your store, products, unit economics, team, targets and current evidence. If the problem is not a fit for our work, we will say so.', output: 'A concise view of the commercial goal, constraints, available data and decisions that matter.' },
  { number: '02', label: 'Diagnosis', title: 'One connected growth system', copy: 'Paid media is not assessed in isolation. We look across acquisition, conversion, retention and measurement to find where additional effort is most likely to pay back.', output: 'A prioritised diagnostic—not a list of every possible marketing task.' },
  { number: '03', label: 'Roadmap', title: 'A sequence the team can execute', copy: 'Work is ordered by evidence, impact, effort and dependency. Owners, measures and decision dates are made explicit so the plan stays useful after the meeting.', output: 'A 30–90 day roadmap with a shared scorecard and a clear first set of actions.' },
  { number: '04', label: 'Operating cadence', title: 'Run, measure, explain, repeat', copy: 'We implement within the agreed scope, monitor the signals that matter and keep a decision log. Reporting explains what changed, what we learned and what happens next.', output: 'Regular commercial reporting, decisions and a living backlog—not a dashboard without interpretation.' },
];
---

<BaseLayout title="How We Work | Ecommerce Growth Process" description="See how Spires Digital diagnoses ecommerce growth constraints, builds a 30–90 day roadmap and runs a transparent optimisation cadence." schema={schema}>
  <Breadcrumbs items={[{ label: 'How we work' }]} />
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="badge">How we work</span>
      <h1>Clarity before activity.</h1>
      <p>We connect commercial context to channel decisions, prioritise the constraint and give every piece of work a reason, an owner and a measure.</p>
      <div class="page-hero-actions"><a href="/contact" class="btn btn-primary btn-lg">Request a growth review</a><a href="/tools/growth-assessment" class="btn btn-outline btn-lg">Diagnose your constraint</a></div>
    </div>
  </section>

  <section class="section surface">
    <div class="container process-list">
      {stages.map(stage => <article class="process-row"><div class="process-index"><span>{stage.number}</span><small>{stage.label}</small></div><div><h2>{stage.title}</h2><p>{stage.copy}</p></div><aside><strong>Useful output</strong><p>{stage.output}</p></aside></article>)}
    </div>
  </section>

  <section class="section surface-warm">
    <div class="container split">
      <div class="split-copy"><span class="eyebrow">What transparency means</span><h2>You keep control of the assets and the decisions.</h2><p>Accounts should be held in your business wherever the platform allows it. You should be able to see what changed, why it changed and how success is being judged.</p></div>
      <div class="principles"><div><strong>Your accounts</strong><span>Direct access to media, analytics and store platforms.</span></div><div><strong>Your evidence</strong><span>Commercial measures alongside platform-reported results.</span></div><div><strong>Your roadmap</strong><span>Priorities, owners and decision dates visible to the team.</span></div><div><strong>Plain English</strong><span>Assumptions and uncertainty explained, not hidden.</span></div></div>
    </div>
  </section>

  <section class="section surface"><div class="container"><div class="section-heading"><span class="eyebrow">Before we begin</span><h2>A productive first conversation needs surprisingly little.</h2><p>If you can share the following, we can spend more time on the decision and less time gathering context.</p></div><div class="grid grid-3"><div class="card"><div class="card-body"><h3>Business target</h3><p>The outcome, timeframe and why it matters now.</p></div></div><div class="card"><div class="card-body"><h3>Economic guardrails</h3><p>Average order value, margin, allowable CAC or your closest estimates.</p></div></div><div class="card"><div class="card-body"><h3>Current evidence</h3><p>Store, analytics and media context. Read-only access can follow after fit is established.</p></div></div></div></div></section>

  <section class="cta-section"><div class="container"><h2>Bring us the constraint, not a polished brief.</h2><p>We will help turn the context into a useful next decision.</p><a href="/contact" class="btn btn-white btn-lg">Request a growth review</a></div></section>
</BaseLayout>

<style>
  .process-list { display: grid; gap: 0; }
  .process-row { display: grid; grid-template-columns: 150px 1fr minmax(260px,.65fr); gap: 2rem; padding: 2.2rem 0; border-bottom: 1px solid var(--line); align-items: start; }
  .process-row:first-child { border-top: 1px solid var(--line); }
  .process-index { display: grid; gap: .25rem; }
  .process-index span { color: var(--violet); font-size: 2rem; font-weight: 850; letter-spacing: -.05em; }
  .process-index small { color: var(--muted); font-size: .72rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .process-row h2 { font-size: clamp(1.55rem,3vw,2.25rem); }
  .process-row > div > p { max-width: 580px; margin-top: .75rem; color: var(--slate); }
  .process-row aside { padding: 1.1rem; border-radius: var(--radius-sm); background: var(--canvas); }
  .process-row aside strong { color: var(--ink); font-size: .78rem; text-transform: uppercase; letter-spacing: .08em; }
  .process-row aside p { margin-top: .35rem; color: var(--slate); font-size: .88rem; }
  .principles { display: grid; grid-template-columns: repeat(2,1fr); gap: 1rem; }
  .principles div { padding: 1.25rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: white; }
  .principles strong, .principles span { display: block; }
  .principles span { margin-top: .35rem; color: var(--slate); font-size: .86rem; }
  @media (max-width: 800px) { .process-row { grid-template-columns: 75px 1fr; gap: 1rem; } .process-row aside { grid-column: 2; } .principles { grid-template-columns: 1fr; } }
</style>

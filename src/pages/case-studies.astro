---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { caseStudies } from '../data/caseStudies';
---

<BaseLayout title="Selected Ecommerce & Performance Outcomes" description="Selected, anonymised Spires Digital client outcomes across ecommerce paid media, CRO, affiliate, Shopify and lead generation.">
  <div class="breadcrumbs-wrap"><Breadcrumbs items={[{ label: 'Results' }]} /></div>
  <section class="page-hero"><div class="container page-hero-content"><span class="badge">Selected outcomes</span><h1>Results need context to be useful.</h1><p>These summaries show the commercial challenge, the work and the reported outcome. Client identities are anonymised where agreements require it. Individual results are not a guarantee of future performance.</p></div></section>
  <section class="section surface"><div class="container results-list">{caseStudies.map((study,index) => <article id={study.slug} class="case-row"><div class="case-index"><span>{String(index+1).padStart(2,'0')}</span><small>{study.industry}</small></div><div class="case-story"><span class="case-service">{study.service}</span><h2>{study.title}</h2><div class="case-columns"><div><h3>The constraint</h3><p>{study.challenge}</p></div><div><h3>The work</h3><p>{study.description}</p></div></div><p class="case-note">Client identity anonymised. Further commercial context can be discussed where confidentiality permits.</p></div><div class="case-outcomes"><span>Selected outcome</span>{study.stats.map(stat => <div><strong>{stat.value}</strong><small>{stat.label}</small></div>)}</div></article>)}</div></section>
  <section class="evidence-note surface-warm"><div class="container split"><div><span class="eyebrow">How to read results</span><h2>Percentages without a baseline can mislead.</h2></div><div><p>We evaluate results against the original commercial problem, the available margin and the quality of measurement. Before starting any engagement, we agree the definition of success and which external factors could affect it.</p><a href="/services/analytics-attribution" class="text-link">See the measurement approach →</a></div></div></section>
  <section class="cta-section"><div class="container"><h2>Your baseline is the only honest starting point.</h2><p>Share the current numbers and we will identify the next commercially useful improvement.</p><a href="/contact" class="btn btn-white btn-lg btn-arrow">Get your growth plan</a></div></section>
</BaseLayout>
<style>.results-list{display:grid;gap:1rem}.case-row{display:grid;grid-template-columns:.25fr 1.4fr .5fr;gap:2rem;padding:clamp(1.4rem,3vw,2.2rem);border:1px solid var(--line);border-radius:var(--radius);background:var(--canvas);scroll-margin-top:110px}.case-row:target{border-color:var(--violet);box-shadow:0 0 0 4px var(--violet-soft)}.case-index{display:grid;align-content:start;gap:.4rem}.case-index span{color:var(--violet-dark);font-weight:850}.case-index small,.case-service{color:var(--muted);font-size:.68rem;font-weight:800;text-transform:uppercase}.case-story h2{margin:.8rem 0 1.5rem;font-size:clamp(1.7rem,3vw,2.5rem)}.case-columns{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}.case-columns h3{margin-bottom:.4rem;font-size:.75rem;text-transform:uppercase}.case-columns p{color:var(--slate);font-size:.84rem}.case-note{margin-top:1.3rem;color:var(--muted);font-size:.68rem}.case-outcomes{display:grid;align-content:start;gap:.7rem;padding-left:1.5rem;border-left:1px solid var(--line)}.case-outcomes>span{color:var(--muted);font-size:.66rem;font-weight:800;text-transform:uppercase}.case-outcomes div{padding:.7rem 0;border-bottom:1px solid var(--line)}.case-outcomes strong,.case-outcomes small{display:block}.case-outcomes strong{color:var(--violet-dark);font-size:1.5rem;letter-spacing:-.04em}.case-outcomes small{color:var(--slate)}.evidence-note{padding:5rem 0}.evidence-note p{color:var(--slate);margin-bottom:1rem}@media(max-width:850px){.case-row{grid-template-columns:auto 1fr}.case-outcomes{grid-column:2;grid-template-columns:repeat(3,1fr);padding:1rem 0 0;border-left:0;border-top:1px solid var(--line)}}@media(max-width:600px){.case-row{grid-template-columns:1fr}.case-outcomes{grid-column:1}.case-columns,.case-outcomes{grid-template-columns:1fr}}</style>

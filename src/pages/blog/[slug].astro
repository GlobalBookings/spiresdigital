---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { blogPosts } from '../../data/blogPosts';
import { blogContent } from '../../data/blogContent';

export function getStaticPaths() {
  const uniquePosts = Array.from(new Map(blogPosts.map(post => [post.slug, post])).values());
  return uniquePosts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = Array.from(new Map(blogPosts.map(item => [item.slug, item])).values()).find(item => item.slug === slug)!;
const content = blogContent[slug];
---

<BlogLayout
  title={post.title}
  description={post.description}
  date={post.date}
  category={post.category}
  image={post.image}
  readTime={post.readTime}
  noindex={!content}
>
  {content ? <Fragment set:html={content} /> : (
    <p>{post.description}</p>
    <h2>This guide is being reviewed</h2>
    <p>We have temporarily removed the draft while it is checked for accuracy. In the meantime, explore our <a href="/tools">free ecommerce tools</a> or <a href="/contact">ask a specific question</a>.</p>
  )}
</BlogLayout>

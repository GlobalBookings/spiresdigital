---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { blogPosts } from '../../data/blogPosts';
---

<BaseLayout title="Blog — Digital Marketing Insights" description="Expert digital marketing insights, PPC strategies, SEO tips, and industry updates from Spires Digital.">
  <Breadcrumbs items={[{ label: 'Blog' }]} />

  <section class="page-hero" style="margin-top: -2rem;">
    <div class="container page-hero-content">
      <span class="badge">Blog</span>
      <h1>Digital Marketing Insights</h1>
      <p>Strategies, tips, and industry updates to help you grow your business online.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {blogPosts.length === 0 ? (
        <div style="text-align: center; padding: 3rem 0;">
          <h2>Coming Soon</h2>
          <p style="color: var(--color-text-light); margin-top: 0.5rem;">We're working on our first articles. Check back soon for digital marketing insights and strategies.</p>
          <a href="/contact" class="btn btn-primary" style="margin-top: 1.5rem;">Get Marketing Advice Now</a>
        </div>
      ) : (
        <div class="grid grid-3">
          {blogPosts.map(post => (
            <a href={`/blog/${post.slug}`} class="card blog-card">
              {post.image && (
                <img src={post.image} alt={post.title} width="400" height="220" loading="lazy" style="width:100%;height:200px;object-fit:cover;" />
              )}
              <div class="card-body">
                <span class="badge" style="font-size: 0.7rem;">{post.category}</span>
                <h3>{post.title}</h3>
                <p>{post.description}</p>
                <div class="card-meta">
                  <span>{post.date}</span>
                  <span>{post.readTime}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Need Expert Marketing Help?</h2>
      <p>Our articles are helpful, but nothing beats a personalised strategy. Get a free audit today.</p>
      <a href="/contact" class="btn btn-white btn-lg">Get Free Audit</a>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-card { text-decoration: none; }
  .blog-card h3 { font-size: 1.05rem; }
  .card-meta { display: flex; gap: 1rem; font-size: 0.8rem; color: var(--color-text-light); margin-top: 0.75rem; }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="This Spires Digital page could not be found." noindex canonicalUrl="https://spiresdigital.com/404/">
  <section class="not-found hero-dark"><div class="container-narrow"><span class="error-code">404</span><h1>This route has reached the end of the funnel.</h1><p>The page may have moved during the rebuild or the address may be incorrect. The most useful destinations are below.</p><div class="page-hero-actions"><a href="/" class="btn btn-primary btn-lg">Go to the homepage</a><a href="/tools" class="btn btn-outline btn-lg">Use a free tool</a></div><div class="route-links"><a href="/industries/ecommerce"><strong>Ecommerce growth</strong><span>See the connected growth model</span></a><a href="/services"><strong>Services</strong><span>Acquire, convert, retain and measure</span></a><a href="/contact"><strong>Growth review</strong><span>Get a tailored opportunity map</span></a></div></div></section>
</BaseLayout>
<style>.not-found{min-height:780px;display:grid;align-items:center}.not-found .container-narrow{position:relative;z-index:1}.error-code{display:block;color:#91eadb;font-size:.78rem;font-weight:850;letter-spacing:.18em}.not-found h1{margin-top:1rem}.route-links{display:grid;grid-template-columns:repeat(3,1fr);gap:.7rem;margin-top:3rem}.route-links a{padding:1rem;border:1px solid rgba(255,255,255,.14);border-radius:var(--radius-sm);background:rgba(255,255,255,.06)}.route-links strong,.route-links span{display:block}.route-links strong{color:white}.route-links span{margin-top:.3rem;color:#9da8ba;font-size:.7rem}@media(max-width:650px){.route-links{grid-template-columns:1fr}}</style>

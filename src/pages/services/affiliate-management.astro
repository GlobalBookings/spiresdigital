---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
---

<BaseLayout title="Affiliate Management" description="Complete affiliate program management including network setup, partner recruitment, and performance optimisation. Spires Digital, Guernsey &amp; Lichfield.">
  <Breadcrumbs items={[{ label: 'Services', href: '/services' }, { label: 'Affiliate Management' }]} />

  <section class="page-hero" style="margin-top: -2rem;">
    <div class="container page-hero-content">
      <span class="badge">Affiliate Management</span>
      <h1>Scale Your Business Through Strategic Partnerships</h1>
      <p>We build and manage affiliate programs that generate consistent revenue through quality partnerships and data-driven optimisation.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 900px;">
      <h2>Our Affiliate Services</h2>
      <div class="grid grid-2" style="margin: 2rem 0;">
        <div class="feature-card">
          <h3>Program Setup</h3>
          <p>Network selection (AWIN, CJ, Rakuten), tracking implementation, commission structures, and terms that attract quality partners.</p>
        </div>
        <div class="feature-card">
          <h3>Partner Recruitment</h3>
          <p>Proactive outreach to identify and recruit affiliates who align with your brand and can drive meaningful revenue.</p>
        </div>
        <div class="feature-card">
          <h3>Performance Optimisation</h3>
          <p>Commission tier management, promotional calendar planning, and ongoing optimisation to maximise affiliate-driven revenue.</p>
        </div>
        <div class="feature-card">
          <h3>Compliance & Monitoring</h3>
          <p>Brand protection, coupon policing, and performance monitoring to ensure your affiliate program maintains quality standards.</p>
        </div>
      </div>

      <h2>Program Launch Process</h2>
      <div class="process-steps">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h3>Discovery & Planning</h3>
            <p>We analyse your business model, margins, and competitors to define the right commission structure, cookie duration, and program terms that attract quality affiliates.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h3>Network Setup</h3>
            <p>We select the best affiliate network for your brand, set up tracking, integrate with your platform, and configure commission tiers, creatives, and reporting dashboards.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h3>Affiliate Recruitment</h3>
            <p>Proactive outreach to content creators, bloggers, comparison sites, and cashback partners. We vet every applicant to protect your brand reputation.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h3>Activation & Growth</h3>
            <p>We onboard new partners with creative assets, promotional calendars, and exclusive offers to drive early momentum and build lasting relationships.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">5</span>
          <div>
            <h3>Optimise & Protect</h3>
            <p>Ongoing performance monitoring, commission tier adjustments, coupon policing, and fraud prevention to maximise ROI while protecting your brand.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section networks-section">
    <div class="container" style="max-width: 900px;">
      <h2>Networks We Work With</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">We're experienced across all major affiliate networks and can advise on which is the best fit for your business and goals.</p>
      <div class="grid grid-4" style="margin-top: 1.5rem;">
        <div class="network-card">
          <h3>AWIN</h3>
          <p>Europe's leading affiliate network with access to over 240,000 active publishers globally.</p>
        </div>
        <div class="network-card">
          <h3>CJ Affiliate</h3>
          <p>One of the largest performance marketing platforms, ideal for brands targeting North American and global audiences.</p>
        </div>
        <div class="network-card">
          <h3>Rakuten</h3>
          <p>Premium network with curated publisher relationships, strong in fashion, retail, and lifestyle verticals.</p>
        </div>
        <div class="network-card">
          <h3>Impact</h3>
          <p>Modern partnership platform with advanced tracking, automation, and influencer management capabilities.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section pricing-section">
    <div class="container" style="max-width: 900px;">
      <h2>Affiliate Management Pricing</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">Flexible pricing models to suit your business stage and budget.</p>
      <div class="pricing-card" style="max-width: 600px; margin: 0 auto;">
        <div class="pricing-header">
          <span class="pricing-label">Growth Partnership</span>
          <span class="pricing-from">Monthly</span>
          <span class="pricing-value">&pound;1,200<span class="pricing-period">/month</span></span>
          <span class="pricing-note">+ 5% of profitable revenue generated</span>
        </div>
        <ul class="pricing-includes">
          <li>Full program setup and management</li>
          <li>Network configuration and tracking</li>
          <li>Affiliate recruitment and onboarding</li>
          <li>Performance reporting and strategy calls</li>
          <li>Coupon policing and compliance monitoring</li>
          <li>Our incentives align with yours -- we grow when you grow</li>
        </ul>
        <p class="pricing-caveat"><a href="/contact">Get in touch</a> to discuss how we can grow your affiliate channel.</p>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container" style="max-width: 900px;">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How long does it take to build an affiliate program?</summary>
          <div class="faq-answer">
            <p>A typical program launch takes 4–6 weeks, including network setup, tracking integration, creative asset preparation, and initial affiliate recruitment. You'll usually see your first affiliate-driven sales within the first two months, with meaningful revenue building over months three to six as the partner base grows.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>What commission rates should I offer?</summary>
          <div class="faq-answer">
            <p>Commission rates vary by industry, but typical ranges are 5–15% for physical products and 15–30% for digital products or subscriptions. We'll analyse your margins, competitor programs, and the affiliate landscape to recommend rates that are competitive enough to attract quality partners without eroding your profitability.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>How do you prevent coupon abuse?</summary>
          <div class="faq-answer">
            <p>We implement strict coupon policing including automated monitoring for unauthorised codes, brand bidding restrictions, and clear program terms. We regularly audit affiliate activity, use attribution modelling to identify last-click coupon hijacking, and take swift action against any partners violating your program terms.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>What networks do you recommend?</summary>
          <div class="faq-answer">
            <p>Our recommendation depends on your business model and target markets. AWIN is excellent for UK and European brands, CJ Affiliate is strong globally, Rakuten suits premium lifestyle brands, and Impact offers the most modern technology with strong influencer features. We'll advise on the best fit during our discovery phase.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Do I need my own tracking?</summary>
          <div class="faq-answer">
            <p>The affiliate network provides its own tracking solution, so you don't need separate tracking software. However, we do recommend integrating with your analytics platform (such as GA4) and ensuring server-side tracking is configured for accurate attribution, especially with increasing browser privacy restrictions.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>How do you recruit affiliates?</summary>
          <div class="faq-answer">
            <p>We use a multi-channel approach: proactive outreach to relevant bloggers and content creators, network marketplace listings, competitor affiliate analysis, social media scouting, and industry event networking. Every applicant is vetted for brand alignment, traffic quality, and promotional methods before being approved into your program.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="section related-section">
    <div class="container" style="max-width: 900px;">
      <h2>You Might Also Need</h2>
      <div class="grid grid-3" style="margin-top: 1.5rem;">
        <a href="/services/meta-ads" class="related-card">
          <h3>Meta Ads</h3>
          <p>Drive targeted traffic from Facebook and Instagram to complement your affiliate program's reach.</p>
        </a>
        <a href="/services/shopify-builds" class="related-card">
          <h3>Shopify Builds</h3>
          <p>Ensure your store converts the traffic your affiliate partners send with an optimised Shopify setup.</p>
        </a>
        <a href="/services/ppc-management" class="related-card">
          <h3>PPC Management</h3>
          <p>Drive high-intent search traffic alongside your affiliate strategy for diversified acquisition.</p>
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How long does it take to build an affiliate program?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A typical program launch takes 4–6 weeks, including network setup, tracking integration, creative asset preparation, and initial affiliate recruitment. You'll usually see your first affiliate-driven sales within the first two months, with meaningful revenue building over months three to six as the partner base grows."
          }
        },
        {
          "@type": "Question",
          "name": "What commission rates should I offer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Commission rates vary by industry, but typical ranges are 5–15% for physical products and 15–30% for digital products or subscriptions. We'll analyse your margins, competitor programs, and the affiliate landscape to recommend rates that are competitive enough to attract quality partners without eroding your profitability."
          }
        },
        {
          "@type": "Question",
          "name": "How do you prevent coupon abuse?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We implement strict coupon policing including automated monitoring for unauthorised codes, brand bidding restrictions, and clear program terms. We regularly audit affiliate activity, use attribution modelling to identify last-click coupon hijacking, and take swift action against any partners violating your program terms."
          }
        },
        {
          "@type": "Question",
          "name": "What networks do you recommend?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our recommendation depends on your business model and target markets. AWIN is excellent for UK and European brands, CJ Affiliate is strong globally, Rakuten suits premium lifestyle brands, and Impact offers the most modern technology with strong influencer features. We'll advise on the best fit during our discovery phase."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need my own tracking?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The affiliate network provides its own tracking solution, so you don't need separate tracking software. However, we do recommend integrating with your analytics platform (such as GA4) and ensuring server-side tracking is configured for accurate attribution, especially with increasing browser privacy restrictions."
          }
        },
        {
          "@type": "Question",
          "name": "How do you recruit affiliates?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We use a multi-channel approach: proactive outreach to relevant bloggers and content creators, network marketplace listings, competitor affiliate analysis, social media scouting, and industry event networking. Every applicant is vetted for brand alignment, traffic quality, and promotional methods before being approved into your program."
          }
        }
      ]
    }
  </script>

  <section class="cta-section">
    <div class="container">
      <h2>Launch Your Affiliate Program</h2>
      <p>Let's discuss how an affiliate program can become a profitable revenue channel for your business.</p>
      <a href="/contact" class="btn btn-white btn-lg">Get Started</a>
    </div>
  </section>
</BaseLayout>

<style>
  .feature-card { padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius); }
  .feature-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .feature-card p { font-size: 0.95rem; color: var(--color-text-light); }
  .process-steps { display: flex; flex-direction: column; gap: 1.5rem; margin: 2rem 0; }
  .step { display: flex; gap: 1.25rem; align-items: start; }
  .step-num { width: 36px; height: 36px; border-radius: 50%; background: var(--color-accent); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; flex-shrink: 0; }
  .step h3 { font-size: 1rem; margin-bottom: 0.25rem; }
  .step p { font-size: 0.92rem; color: var(--color-text-light); }
  .network-card { padding: 1.25rem; background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-sm); text-align: center; }
  .network-card h3 { font-size: 1.05rem; margin-bottom: 0.4rem; color: var(--color-accent); }
  .network-card p { font-size: 0.85rem; color: var(--color-text-light); }
  .pricing-card { background: var(--color-white); border: 2px solid var(--color-border); border-radius: var(--radius); padding: 2rem; text-align: center; }
  .pricing-header { margin-bottom: 1.5rem; }
  .pricing-label { display: block; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-accent); background: rgba(79, 70, 229, 0.1); padding: 0.25rem 0.75rem; border-radius: 100px; display: inline-block; margin-bottom: 0.5rem; }
  .pricing-from { display: block; font-size: 0.85rem; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; }
  .pricing-value { display: block; font-size: 2.5rem; font-weight: 800; color: var(--color-accent); }
  .pricing-period { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .pricing-includes { list-style: none; text-align: left; margin: 1.5rem 0; padding: 0; }
  .pricing-includes li { padding: 0.5rem 0; border-bottom: 1px solid var(--color-border); font-size: 0.95rem; padding-left: 1.5rem; position: relative; }
  .pricing-includes li::before { content: '✓'; position: absolute; left: 0; color: var(--color-success); font-weight: 700; }
  .pricing-caveat { font-size: 0.85rem; color: var(--color-text-light); }
  .pricing-caveat a { color: var(--color-accent); text-decoration: underline; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.5rem; }
  .faq-item { background: var(--color-bg-alt); border-radius: var(--radius-sm); overflow: hidden; }
  .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; font-size: 0.95rem; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--color-accent); font-weight: 700; flex-shrink: 0; margin-left: 1rem; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-answer { padding: 0 1.25rem 1rem; }
  .faq-answer p { font-size: 0.92rem; color: var(--color-text-light); line-height: 1.7; }
  .related-card { display: block; padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius); transition: all 0.2s ease; border: 1px solid transparent; text-decoration: none; }
  .related-card:hover { border-color: var(--color-accent); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .related-card h3 { font-size: 1.05rem; margin-bottom: 0.4rem; color: var(--color-accent); }
  .related-card p { font-size: 0.9rem; color: var(--color-text-light); }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const groups = [
  { id: 'acquire', index: '01', title: 'Acquire', intro: 'Reach the right customers at a cost your margins can support.', services: [
    { href: '/services/ppc-management', title: 'Google Shopping & PPC', text: 'High-intent search, product feeds and campaign systems tied to profit.' },
    { href: '/services/meta-ads', title: 'Meta ads', text: 'Creative-led prospecting and retargeting built around repeatable testing.' },
    { href: '/services/ecommerce-seo', title: 'Ecommerce SEO', text: 'Technical, category and product-page growth that compounds over time.' },
    { href: '/services/affiliate-management', title: 'Affiliate growth', text: 'Partner recruitment, activation and margin-aware programme management.' },
  ]},
  { id: 'convert', index: '02', title: 'Convert', intro: 'Remove the friction between a qualified visit and a profitable order.', services: [
    { href: '/services/cro-shopify', title: 'CRO & Shopify', text: 'Research-led experiments, product journeys and Shopify improvements.' },
  ]},
  { id: 'retain', index: '03', title: 'Retain', intro: 'Increase the value of every customer after the first transaction.', services: [
    { href: '/services/email-retention', title: 'Email & retention', text: 'Lifecycle strategy, automation and segmentation focused on repeat revenue.' },
  ]},
  { id: 'measure', index: '04', title: 'Measure', intro: 'Turn fragmented channel data into confident commercial decisions.', services: [
    { href: '/services/analytics-attribution', title: 'Analytics & attribution', text: 'Tracking, blended reporting and targets grounded in contribution margin.' },
  ]},
];
---

<BaseLayout title="Ecommerce Growth Services" description="A connected ecommerce growth system covering customer acquisition, conversion, retention and measurement.">
  <div class="breadcrumbs-wrap"><Breadcrumbs items={[{ label: 'Services' }]} /></div>
  <section class="page-hero"><div class="container page-hero-content"><span class="badge">The ecommerce growth system</span><h1>Services organised around the customer journey.</h1><p>Start with the commercial constraint. Bring in the disciplines needed to remove it. Keep every channel accountable to the same definition of profitable growth.</p><div class="page-hero-actions"><a href="/contact" class="btn btn-primary btn-lg btn-arrow">Get a tailored growth plan</a><a href="/tools/ecommerce-profit-calculator" class="btn btn-outline btn-lg">Calculate your targets</a></div></div></section>
  <section class="section surface"><div class="container service-groups">
    {groups.map(group => <section id={group.id} class="service-group"><div class="group-heading"><span>{group.index}</span><div><h2>{group.title}</h2><p>{group.intro}</p></div></div><div class="group-services">{group.services.map(service => <a href={service.href}><span>Service</span><h3>{service.title}</h3><p>{service.text}</p><strong>Explore <span aria-hidden="true">→</span></strong></a>)}</div></section>)}
  </div></section>
  <section class="section surface-warm"><div class="container split"><div class="split-copy"><span class="eyebrow">Not sure where to start?</span><h2>Use the free store growth assessment.</h2><p>Answer a short set of questions across acquisition, conversion, retention and measurement. The tool will identify the most likely constraint and give you immediate next steps.</p><a href="/tools/growth-assessment" class="btn btn-primary btn-arrow">Find your growth constraint</a></div><div class="tool-steps"><div><span>01</span><p><strong>No login</strong><small>Get the result immediately</small></p></div><div><span>02</span><p><strong>Commercially focused</strong><small>Built around profit, not vanity scores</small></p></div><div><span>03</span><p><strong>Clear next move</strong><small>Know what to prioritise first</small></p></div></div></div></section>
  <section class="cta-section"><div class="container"><h2>Build the system your next stage of growth needs.</h2><p>We will review the whole journey and recommend the smallest useful scope.</p><a href="/contact" class="btn btn-white btn-lg btn-arrow">Get your free growth plan</a></div></section>
</BaseLayout>

<style>
  .service-groups { display: grid; gap: 5rem; }
  .service-group { display: grid; grid-template-columns: .55fr 1.45fr; gap: 3rem; padding-top: 2rem; border-top: 1px solid var(--line); scroll-margin-top: 110px; }
  .group-heading { display: grid; grid-template-columns: auto 1fr; gap: 1rem; align-items: start; }
  .group-heading > span { color: var(--violet-dark); font-size: .7rem; font-weight: 800; }
  .group-heading p { margin-top: .7rem; color: var(--slate); }
  .group-services { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .group-services a { min-height: 250px; padding: 1.5rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--canvas); transition: transform var(--transition), box-shadow var(--transition); }
  .group-services a:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .group-services a > span { color: var(--violet-dark); font-size: .68rem; font-weight: 800; text-transform: uppercase; }
  .group-services h3 { margin: 2.4rem 0 .7rem; }
  .group-services p { color: var(--slate); font-size: .86rem; }
  .group-services strong { display: block; margin-top: 1rem; color: var(--violet-dark); font-size: .78rem; }
  .tool-steps { display: grid; gap: .7rem; }
  .tool-steps > div { display: grid; grid-template-columns: auto 1fr; gap: .8rem; padding: 1.1rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: white; }
  .tool-steps > div > span { display: grid; width: 34px; height: 34px; place-items: center; border-radius: 50%; background: var(--ink); color: white; font-size: .65rem; font-weight: 800; }
  .tool-steps strong, .tool-steps small { display: block; }.tool-steps small { color: var(--slate); }
  @media (max-width: 850px) { .service-group { grid-template-columns: 1fr; } }
  @media (max-width: 620px) { .group-services { grid-template-columns: 1fr; } }
</style>

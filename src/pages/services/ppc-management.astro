---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
---

<BaseLayout title="PPC Management — Google & Bing Ads" description="Expert PPC management for Google Ads and Bing Ads. Transparent reporting, proven ROI, and full account access. Spires Digital, Guernsey &amp; Lichfield.">
  <Breadcrumbs items={[{ label: 'Services', href: '/services' }, { label: 'PPC Management' }]} />

  <section class="page-hero" style="margin-top: -2rem;">
    <div class="container page-hero-content">
      <span class="badge">PPC Management</span>
      <h1>Google & Bing Ads Management That Delivers ROI</h1>
      <p>Data-driven PPC campaigns that convert clicks into customers. We manage over &pound;10M in ad spend with an average 250% ROAS improvement.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 900px;">
      <div class="grid grid-2" style="margin-bottom: 3rem;">
        <div class="stat-highlight">
          <span class="stat-value">250%</span>
          <span class="stat-label">Average ROAS Improvement</span>
        </div>
        <div class="stat-highlight">
          <span class="stat-value">&pound;10M+</span>
          <span class="stat-label">Ad Spend Managed</span>
        </div>
      </div>

      <h2>What's Included</h2>
      <div class="grid grid-2" style="margin: 2rem 0;">
        <div class="feature-card">
          <h3>Search Campaigns</h3>
          <p>High-intent keyword targeting across Google and Bing. We build campaigns around your most profitable search terms with tight ad group structures.</p>
        </div>
        <div class="feature-card">
          <h3>Shopping Campaigns</h3>
          <p>Product feed optimisation, smart bidding strategies, and Performance Max campaigns to maximise your e-commerce revenue.</p>
        </div>
        <div class="feature-card">
          <h3>Conversion Tracking</h3>
          <p>Proper GA4 and Google Ads conversion tracking setup. We ensure every lead and sale is tracked accurately for data-driven decisions.</p>
        </div>
        <div class="feature-card">
          <h3>Transparent Reporting</h3>
          <p>Full access to your ad accounts. Monthly performance reports with clear insights on spend, conversions, and ROI.</p>
        </div>
      </div>

      <h2>Our PPC Process</h2>
      <div class="process-steps">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h3>Audit & Strategy</h3>
            <p>We audit your current campaigns (or start fresh), research keywords, and build a strategy aligned with your business goals.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h3>Build & Launch</h3>
            <p>Campaign structure, ad copy, extensions, and conversion tracking are all set up before a single penny is spent.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h3>Optimise & Scale</h3>
            <p>Continuous bid management, A/B testing, negative keyword refinement, and budget reallocation based on performance data.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h3>Report & Adapt</h3>
            <p>Monthly strategy calls with clear reporting. We adapt to market changes and scale what's working.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 900px;">
      <h2>Platforms We Manage</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">We run paid search and display campaigns across all major advertising platforms, ensuring your budget is allocated where it delivers the best returns.</p>
      <div class="grid grid-3" style="margin: 2rem 0;">
        <div class="platform-card">
          <h3>Google Ads</h3>
          <p>Search, Shopping, Display, and Performance Max campaigns. As a Google Partner, we stay ahead of platform updates and have access to beta features.</p>
        </div>
        <div class="platform-card">
          <h3>Microsoft (Bing) Ads</h3>
          <p>Often overlooked, Bing Ads delivers lower CPCs and higher conversion rates for many industries. We import and optimise campaigns across both platforms.</p>
        </div>
        <div class="platform-card">
          <h3>YouTube Ads</h3>
          <p>Video advertising for brand awareness and remarketing. We manage TrueView, bumper ads, and in-feed video campaigns to reach engaged audiences.</p>
        </div>
      </div>
      <div class="tip-box">
        <strong>Multi-platform strategy:</strong> Running ads across Google, Bing, and YouTube simultaneously typically improves overall ROAS by 15–25%. We manage the full picture so your budget works harder.
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--color-bg-alt);">
    <div class="container" style="max-width: 900px;">
      <h2>PPC Management Pricing</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">Transparent pricing with no hidden fees. You own your ad accounts, and we never lock you into long-term contracts.</p>
      <div class="pricing-indicator" style="max-width: 600px; margin: 2rem auto;">
        <h3>Growth Partnership Model</h3>
        <p style="font-size: 1.1rem; margin-bottom: 1rem;"><strong>&pound;1,200/month</strong> + <strong>5% of profitable revenue</strong> generated from your campaigns.</p>
        <p>Our interests are fully aligned with yours. We earn more when you earn more, which means we're laser-focused on profitability, not vanity metrics. The base fee covers all campaign management, reporting, and strategy. The revenue share only kicks in on profit we help generate.</p>
      </div>
      <div class="tip-box">
        <strong>No lock-in contracts.</strong> We work on a rolling monthly basis. If we're not delivering results, you're free to leave — but our clients tend to stay. <a href="/contact">Get started</a>.
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 900px;">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-question">How quickly will I see results from PPC?</summary>
          <div class="faq-answer">
            <p>You can see traffic and clicks from day one — that's the beauty of paid search. However, meaningful optimisation takes 4–8 weeks as we gather data, refine targeting, and test ad copy. Most clients see a significant ROAS improvement within the first 90 days.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Do I own my ad account?</summary>
          <div class="faq-answer">
            <p>Absolutely. Your Google Ads, Bing Ads, and any other accounts are set up in your name. We operate as managers on your account. If you ever part ways with us, you keep everything — campaigns, data, conversion history, the lot.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">What's the minimum ad budget you recommend?</summary>
          <div class="faq-answer">
            <p>We typically recommend a minimum of &pound;1,000/month in ad spend for Google Ads to generate enough data for meaningful optimisation. For competitive industries, &pound;2,000–&pound;5,000/month is more realistic. We'll advise honestly during our initial consultation — we won't take your money if the budget won't deliver results.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">How do you report on performance?</summary>
          <div class="faq-answer">
            <p>You'll receive a detailed monthly report covering spend, clicks, conversions, cost per acquisition, and ROAS. We also schedule a monthly strategy call to walk through results and discuss upcoming optimisations. Plus, you have 24/7 access to your ad accounts and a live dashboard.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">What if I already have campaigns running?</summary>
          <div class="faq-answer">
            <p>We start with a comprehensive audit of your existing campaigns. We'll identify what's working, what's wasting budget, and where the opportunities are. Rather than starting from scratch, we restructure and optimise what you have — preserving valuable historical data and Quality Scores.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Do you manage Shopping and Performance Max campaigns?</summary>
          <div class="faq-answer">
            <p>Yes, Shopping and Performance Max are core to our e-commerce PPC offering. We handle product feed optimisation, campaign structure, bidding strategies, and asset group creation. If you're running a <a href="/services/shopify-builds">Shopify store</a>, we can integrate your product feed directly.</p>
          </div>
        </details>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How quickly will I see results from PPC?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "You can see traffic and clicks from day one. However, meaningful optimisation takes 4–8 weeks as we gather data, refine targeting, and test ad copy. Most clients see a significant ROAS improvement within the first 90 days."
            }
          },
          {
            "@type": "Question",
            "name": "Do I own my ad account?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. Your Google Ads, Bing Ads, and any other accounts are set up in your name. We operate as managers on your account. If you ever part ways with us, you keep everything — campaigns, data, conversion history, the lot."
            }
          },
          {
            "@type": "Question",
            "name": "What's the minimum ad budget you recommend?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We typically recommend a minimum of £1,000/month in ad spend for Google Ads to generate enough data for meaningful optimisation. For competitive industries, £2,000–£5,000/month is more realistic."
            }
          },
          {
            "@type": "Question",
            "name": "How do you report on performance?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "You'll receive a detailed monthly report covering spend, clicks, conversions, cost per acquisition, and ROAS. We also schedule a monthly strategy call to walk through results and discuss upcoming optimisations."
            }
          },
          {
            "@type": "Question",
            "name": "What if I already have campaigns running?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We start with a comprehensive audit of your existing campaigns. We identify what's working, what's wasting budget, and where the opportunities are. Rather than starting from scratch, we restructure and optimise what you have."
            }
          },
          {
            "@type": "Question",
            "name": "Do you manage Shopping and Performance Max campaigns?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, Shopping and Performance Max are core to our e-commerce PPC offering. We handle product feed optimisation, campaign structure, bidding strategies, and asset group creation."
            }
          }
        ]
      })} />
    </div>
  </section>

  <section class="section" style="background: var(--color-bg-alt);">
    <div class="container" style="max-width: 900px;">
      <h2>You Might Also Need</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">PPC works best as part of a broader digital strategy. These services complement your paid search campaigns.</p>
      <div class="grid grid-3" style="margin: 2rem 0;">
        <a href="/services/meta-ads" class="related-service-card">
          <h3>Meta Ads</h3>
          <p>Retarget your PPC visitors on Facebook and Instagram to stay top of mind and drive repeat conversions.</p>
        </a>
        <a href="/services/shopify-builds" class="related-service-card">
          <h3>Shopify Builds</h3>
          <p>Ensure your landing pages and product pages convert the traffic your PPC campaigns are sending.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Get a Free PPC Audit</h2>
      <p>We'll review your current campaigns and identify opportunities to improve your ROAS.</p>
      <a href="/contact" class="btn btn-white btn-lg">Request Free Audit</a>
    </div>
  </section>
</BaseLayout>

<style>
  .stat-highlight { text-align: center; padding: 2rem; background: var(--color-bg-alt); border-radius: var(--radius); }
  .feature-card { padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius); }
  .feature-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .feature-card p { font-size: 0.95rem; color: var(--color-text-light); }
  .process-steps { display: flex; flex-direction: column; gap: 1.5rem; margin: 2rem 0; }
  .step { display: flex; gap: 1.25rem; align-items: start; }
  .step-num { width: 36px; height: 36px; border-radius: 50%; background: var(--color-accent); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; flex-shrink: 0; }
  .step h3 { font-size: 1rem; margin-bottom: 0.25rem; }
  .step p { font-size: 0.92rem; color: var(--color-text-light); }

  .platform-card { padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius); border: 1px solid var(--color-border); }
  .platform-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .platform-card p { font-size: 0.95rem; color: var(--color-text-light); }

  .pricing-indicator { padding: 2rem; background: var(--color-white); border-radius: var(--radius); border: 1px solid var(--color-border); }
  .pricing-indicator h3 { font-size: 1.1rem; margin-bottom: 0.75rem; }
  .pricing-indicator p { font-size: 0.95rem; color: var(--color-text-light); line-height: 1.7; }

  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin: 2rem 0; }
  .faq-item { background: var(--color-bg-alt); border-radius: var(--radius); overflow: hidden; }
  .faq-question { padding: 1.25rem 1.5rem; font-weight: 600; font-size: 1rem; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; font-size: 1.25rem; font-weight: 700; color: var(--color-accent); flex-shrink: 0; margin-left: 1rem; }
  details[open] .faq-question::after { content: '−'; }
  .faq-answer { padding: 0 1.5rem 1.25rem; }
  .faq-answer p { font-size: 0.95rem; color: var(--color-text-light); line-height: 1.7; }
  .faq-answer a { color: var(--color-accent); text-decoration: underline; }

  .related-service-card { display: block; padding: 1.5rem; background: var(--color-white); border-radius: var(--radius); border: 1px solid var(--color-border); text-decoration: none; color: inherit; transition: box-shadow var(--transition), border-color var(--transition); }
  .related-service-card:hover { box-shadow: var(--shadow-md); border-color: var(--color-accent); }
  .related-service-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--color-accent); }
  .related-service-card p { font-size: 0.9rem; color: var(--color-text-light); }

  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 768px) {
    .grid-3 { grid-template-columns: 1fr; }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
---

<BaseLayout title="Meta Ads — Facebook & Instagram Advertising" description="Facebook and Instagram advertising that drives engagement and conversions. Expert Meta Ads management from Spires Digital.">
  <Breadcrumbs items={[{ label: 'Services', href: '/services' }, { label: 'Meta Ads' }]} />

  <section class="page-hero" style="margin-top: -2rem;">
    <div class="container page-hero-content">
      <span class="badge">Meta Ads Management</span>
      <h1>Facebook & Instagram Ads That Convert</h1>
      <p>Reach your ideal customers with targeted social advertising that drives real business results, not just likes and follows.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 900px;">
      <h2>What We Manage</h2>
      <div class="grid grid-2" style="margin: 2rem 0;">
        <div class="feature-card">
          <h3>Campaign Strategy</h3>
          <p>Full-funnel advertising across Facebook, Instagram, and Messenger. From brand awareness to retargeting and conversion campaigns.</p>
        </div>
        <div class="feature-card">
          <h3>Audience Targeting</h3>
          <p>Custom audiences, lookalikes, interest-based targeting, and dynamic retargeting to reach the right people at the right time.</p>
        </div>
        <div class="feature-card">
          <h3>Creative Testing</h3>
          <p>Systematic A/B testing of ad creative, copy, and formats. We find what resonates with your audience and scale it.</p>
        </div>
        <div class="feature-card">
          <h3>Catalogue & Shopping</h3>
          <p>Dynamic product ads, catalogue campaigns, and Instagram Shopping setup for e-commerce brands.</p>
        </div>
      </div>

      <div class="tip-box">
        <strong>Did you know?</strong> Meta advertising reaches over 3 billion users globally. With the right targeting, even a modest budget can generate significant ROI.
      </div>

      <h2>Our Meta Ads Process</h2>
      <div class="process-steps">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h3>Discovery & Audit</h3>
            <p>We review your existing Meta Ads account (or set one up), analyse your audience, and map out the full customer journey from awareness to conversion.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h3>Strategy & Creative</h3>
            <p>We develop audience segments, craft compelling ad creative, and plan campaign structures across Facebook and Instagram to hit your objectives.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h3>Launch & Test</h3>
            <p>Campaigns go live with structured A/B tests on creative, copy, and audiences. We install the Meta Pixel and set up Conversions API for accurate tracking.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h3>Optimise & Scale</h3>
            <p>Continuous optimisation based on real performance data. We kill underperformers, scale winners, and refine targeting to improve ROAS week over week.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">5</span>
          <div>
            <h3>Report & Strategise</h3>
            <p>Monthly reporting with clear insights on spend, conversions, and cost per acquisition. Strategy calls to plan the next phase of growth.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section pricing-section">
    <div class="container" style="max-width: 900px;">
      <h2>Meta Ads Pricing</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">Transparent pricing with no hidden fees. You always retain full ownership and access to your ad accounts.</p>
      <div class="pricing-card">
        <div class="pricing-header">
          <span class="pricing-from">Growth Partnership</span>
          <span class="pricing-value">&pound;1,200<span class="pricing-period">/month</span></span>
          <span class="pricing-note">+ 5% of profitable revenue generated</span>
        </div>
        <ul class="pricing-includes">
          <li>Full campaign setup and management</li>
          <li>Custom audience creation and lookalike targeting</li>
          <li>Ad creative direction and copywriting</li>
          <li>Meta Pixel and Conversions API setup</li>
          <li>A/B testing across creative, copy, and audiences</li>
          <li>Monthly performance reporting and strategy calls</li>
        </ul>
        <p class="pricing-caveat">Our interests are aligned with yours -- we earn more when you earn more. <a href="/contact">Get in touch</a> to discuss.</p>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container" style="max-width: 900px;">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What budget do I need for Facebook Ads?</summary>
          <div class="faq-answer">
            <p>We generally recommend a minimum ad spend of &pound;500–&pound;1,000 per month to generate enough data for meaningful optimisation. That said, we've seen strong results from smaller budgets in niche markets. During our strategy session, we'll recommend a budget that aligns with your goals and audience size.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>How do you handle ad creative?</summary>
          <div class="faq-answer">
            <p>We provide creative direction, copywriting, and can work with your existing assets or brief in new designs. For brands needing full creative production, we collaborate with trusted designers and videographers. We believe in testing multiple creative angles to find what resonates with your audience.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>What's the difference between boosting a post and running proper ads?</summary>
          <div class="faq-answer">
            <p>Boosting is a simplified version of advertising that limits your targeting, placement, and optimisation options. Running ads through Meta Ads Manager gives us full control over audience targeting, bid strategy, creative testing, and conversion tracking. The difference in performance is significant — proper campaign structures consistently deliver better results and lower cost per acquisition.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>How long until I see results?</summary>
          <div class="faq-answer">
            <p>Most campaigns begin generating leads or sales within the first two weeks. However, the real optimisation happens over the first 4–8 weeks as we gather enough data to refine audiences, creative, and bidding. We typically see significant ROAS improvements by month two or three.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Do you manage Instagram ads too?</summary>
          <div class="faq-answer">
            <p>Absolutely. Facebook and Instagram are both part of the Meta advertising ecosystem, so we manage campaigns across both platforms simultaneously. We optimise placement across Facebook Feed, Instagram Feed, Stories, Reels, and Messenger to reach your audience wherever they're most engaged.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>What targeting options do you use?</summary>
          <div class="faq-answer">
            <p>We use a layered approach including custom audiences (website visitors, email lists, past customers), lookalike audiences built from your best customers, interest and behaviour-based targeting, and demographic targeting. We also leverage Meta's Advantage+ audience features where appropriate, always testing to find the most profitable segments.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="section related-section">
    <div class="container" style="max-width: 900px;">
      <h2>You Might Also Need</h2>
      <div class="grid grid-3" style="margin-top: 1.5rem;">
        <a href="/services/ppc-management" class="related-card">
          <h3>PPC Management</h3>
          <p>Complement your social ads with high-intent Google and Bing search campaigns for full-funnel coverage.</p>
        </a>
        <a href="/services/shopify-builds" class="related-card">
          <h3>Shopify Builds</h3>
          <p>Make sure your store is optimised to convert the traffic your Meta Ads campaigns drive.</p>
        </a>
        <a href="/services/affiliate-management" class="related-card">
          <h3>Affiliate Management</h3>
          <p>Add a performance-based channel alongside your paid social to diversify your acquisition mix.</p>
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What budget do I need for Facebook Ads?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We generally recommend a minimum ad spend of £500–£1,000 per month to generate enough data for meaningful optimisation. That said, we've seen strong results from smaller budgets in niche markets. During our strategy session, we'll recommend a budget that aligns with your goals and audience size."
          }
        },
        {
          "@type": "Question",
          "name": "How do you handle ad creative?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We provide creative direction, copywriting, and can work with your existing assets or brief in new designs. For brands needing full creative production, we collaborate with trusted designers and videographers. We believe in testing multiple creative angles to find what resonates with your audience."
          }
        },
        {
          "@type": "Question",
          "name": "What's the difference between boosting a post and running proper ads?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Boosting is a simplified version of advertising that limits your targeting, placement, and optimisation options. Running ads through Meta Ads Manager gives us full control over audience targeting, bid strategy, creative testing, and conversion tracking. The difference in performance is significant — proper campaign structures consistently deliver better results and lower cost per acquisition."
          }
        },
        {
          "@type": "Question",
          "name": "How long until I see results?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most campaigns begin generating leads or sales within the first two weeks. However, the real optimisation happens over the first 4–8 weeks as we gather enough data to refine audiences, creative, and bidding. We typically see significant ROAS improvements by month two or three."
          }
        },
        {
          "@type": "Question",
          "name": "Do you manage Instagram ads too?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. Facebook and Instagram are both part of the Meta advertising ecosystem, so we manage campaigns across both platforms simultaneously. We optimise placement across Facebook Feed, Instagram Feed, Stories, Reels, and Messenger to reach your audience wherever they're most engaged."
          }
        },
        {
          "@type": "Question",
          "name": "What targeting options do you use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We use a layered approach including custom audiences (website visitors, email lists, past customers), lookalike audiences built from your best customers, interest and behaviour-based targeting, and demographic targeting. We also leverage Meta's Advantage+ audience features where appropriate, always testing to find the most profitable segments."
          }
        }
      ]
    }
  </script>

  <section class="cta-section">
    <div class="container">
      <h2>Start Advertising on Meta</h2>
      <p>Get a free strategy session to discuss how Meta Ads can grow your business.</p>
      <a href="/contact" class="btn btn-white btn-lg">Book Free Consultation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .feature-card { padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius); }
  .feature-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .feature-card p { font-size: 0.95rem; color: var(--color-text-light); }
  .process-steps { display: flex; flex-direction: column; gap: 1.5rem; margin: 2rem 0; }
  .step { display: flex; gap: 1.25rem; align-items: start; }
  .step-num { width: 36px; height: 36px; border-radius: 50%; background: var(--color-accent); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; flex-shrink: 0; }
  .step h3 { font-size: 1rem; margin-bottom: 0.25rem; }
  .step p { font-size: 0.92rem; color: var(--color-text-light); }
  .pricing-card { background: var(--color-white); border: 2px solid var(--color-border); border-radius: var(--radius); padding: 2rem; text-align: center; }
  .pricing-header { margin-bottom: 1.5rem; }
  .pricing-from { display: block; font-size: 0.85rem; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; }
  .pricing-value { display: block; font-size: 2.5rem; font-weight: 800; color: var(--color-accent); }
  .pricing-period { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .pricing-note { display: block; font-size: 0.9rem; color: var(--color-text-light); margin-top: 0.25rem; }
  .pricing-includes { list-style: none; text-align: left; margin: 1.5rem 0; padding: 0; }
  .pricing-includes li { padding: 0.5rem 0; border-bottom: 1px solid var(--color-border); font-size: 0.95rem; padding-left: 1.5rem; position: relative; }
  .pricing-includes li::before { content: '✓'; position: absolute; left: 0; color: var(--color-success); font-weight: 700; }
  .pricing-caveat { font-size: 0.85rem; color: var(--color-text-light); margin-top: 1rem; }
  .pricing-caveat a { color: var(--color-accent); text-decoration: underline; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.5rem; }
  .faq-item { background: var(--color-bg-alt); border-radius: var(--radius-sm); overflow: hidden; }
  .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; font-size: 0.95rem; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--color-accent); font-weight: 700; flex-shrink: 0; margin-left: 1rem; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-answer { padding: 0 1.25rem 1rem; }
  .faq-answer p { font-size: 0.92rem; color: var(--color-text-light); line-height: 1.7; }
  .related-card { display: block; padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius); transition: all 0.2s ease; border: 1px solid transparent; text-decoration: none; }
  .related-card:hover { border-color: var(--color-accent); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .related-card h3 { font-size: 1.05rem; margin-bottom: 0.4rem; color: var(--color-accent); }
  .related-card p { font-size: 0.9rem; color: var(--color-text-light); }
</style>

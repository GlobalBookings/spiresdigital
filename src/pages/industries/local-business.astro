---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
---

<BaseLayout title="Digital Marketing for Local Businesses" description="Local digital marketing that puts your business at the top of local search. Google Business Profile and targeted PPC from Spires Digital, Guernsey &amp; Lichfield.">
  <Breadcrumbs items={[{ label: 'Industries', href: '/industries/local-business' }, { label: 'Local Business' }]} />

  <section class="page-hero" style="margin-top: -2rem;">
    <div class="container page-hero-content">
      <span class="badge">Local Business Marketing</span>
      <h1>Digital Marketing for Local Businesses</h1>
      <p>Dominate your local area with targeted SEO, Google Business Profile optimisation, and location-based PPC campaigns that put your business in front of customers who are ready to buy.</p>
    </div>
  </section>

  <!-- The Challenge -->
  <section class="section">
    <div class="container" style="max-width: 900px;">
      <h2>The Local Marketing Challenge</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">Local businesses face unique obstacles in the digital landscape. The competition for local search visibility has never been fiercer.</p>
      <div class="grid grid-2" style="margin-bottom: 3rem;">
        <div class="challenge-card">
          <div class="icon-box">📍</div>
          <h3>Invisible in Local Search</h3>
          <p>If you're not in the Google Map Pack or ranking for "near me" searches, your competitors are getting the enquiries that should be yours.</p>
        </div>
        <div class="challenge-card">
          <div class="icon-box">⭐</div>
          <h3>Review Management</h3>
          <p>Online reviews directly impact your local rankings and customer trust. A handful of negative reviews — or too few reviews altogether — can cost you business.</p>
        </div>
        <div class="challenge-card">
          <div class="icon-box">🎯</div>
          <h3>Wasted Ad Spend</h3>
          <p>Without tight geographic targeting and local keyword strategy, PPC budgets get eaten up by clicks from outside your service area or irrelevant searches.</p>
        </div>
        <div class="challenge-card">
          <div class="icon-box">🏗️</div>
          <h3>Inconsistent Online Presence</h3>
          <p>Mismatched business information across directories, outdated Google Business Profiles, and poor local citations all damage your search visibility and credibility.</p>
        </div>
      </div>

      <!-- Our Approach -->
      <h2>Our Approach to Local Growth</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">We combine local SEO expertise with targeted paid campaigns to make your business the obvious choice in your area.</p>
      <div class="process-steps">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h3>Local Visibility Audit</h3>
            <p>We audit your Google Business Profile, local citations, reviews, on-site SEO, and competitor landscape to identify exactly where you're falling behind.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h3>Google Business Profile Optimisation</h3>
            <p>Complete GBP setup and optimisation — categories, attributes, photos, posts, Q&amp;A, and review response strategy to maximise your Map Pack presence.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h3>Local SEO &amp; Citations</h3>
            <p>On-page local optimisation, consistent NAP (Name, Address, Phone) citations across key directories, and locally-focused content to build topical authority.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h3>Geo-Targeted PPC</h3>
            <p>Location-specific Google Ads campaigns with tight radius targeting, local ad extensions, and call tracking to drive immediate enquiries from your service area.</p>
          </div>
        </div>
      </div>

      <div class="tip-box" style="margin-top: 2rem;">
        <strong>Did you know?</strong> 76% of people who search for something "near me" on their phone visit a business within 24 hours. Local SEO isn't optional — it's how your customers find you.
      </div>
    </div>
  </section>

  <!-- Services for Local Business -->
  <section class="section" style="background: var(--color-bg-alt);">
    <div class="container" style="max-width: 900px;">
      <h2>Services for Local Businesses</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">Every service is tailored to help local businesses attract more customers from their surrounding area.</p>
      <div class="grid grid-2">
        <a href="/services/ppc-management" class="service-link-card">
          <h3>Local PPC</h3>
          <p>Geo-targeted Google Ads with call extensions, location targeting, and budget controls that ensure every penny is spent reaching customers in your area.</p>
          <span class="link-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats / Results -->
  <section class="section">
    <div class="container" style="max-width: 900px;">
      <h2 style="text-align: center;">Results We Deliver for Local Businesses</h2>
      <p style="text-align: center; color: var(--color-text-light); margin-bottom: 2rem;">Average performance improvements across our local business client portfolio.</p>
      <div class="stat-grid">
        <div class="stat">
          <div class="stat-value">Top 3</div>
          <div class="stat-label">Map Pack Rankings</div>
        </div>
        <div class="stat">
          <div class="stat-value">+180%</div>
          <div class="stat-label">Local Search Visibility</div>
        </div>
        <div class="stat">
          <div class="stat-value">+95%</div>
          <div class="stat-label">Enquiry &amp; Call Volume</div>
        </div>
        <div class="stat">
          <div class="stat-value">4.8★</div>
          <div class="stat-label">Avg. Client Review Score</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section" style="background: var(--color-bg-alt);">
    <div class="container" style="max-width: 900px;">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How long does it take to rank in the Google Map Pack?</summary>
          <p>It depends on your current position, competition, and industry. Most local businesses see meaningful improvements within 2–4 months of consistent optimisation. Highly competitive areas may take longer, but we focus on quick wins first to build momentum.</p>
        </details>
        <details class="faq-item">
          <summary>Do you help with Google Business Profile management?</summary>
          <p>Yes — Google Business Profile is central to our local SEO service. We handle full setup and ongoing optimisation, including categories, photos, posts, Q&amp;A management, and review response strategy to keep your profile active and competitive.</p>
        </details>
        <details class="faq-item">
          <summary>Can you help us get more customer reviews?</summary>
          <p>Absolutely. We implement review generation strategies that make it easy for satisfied customers to leave positive reviews. We also help you respond professionally to all reviews, which builds trust and signals activity to Google.</p>
        </details>
        <details class="faq-item">
          <summary>What budget do local PPC campaigns need?</summary>
          <p>Local PPC can be surprisingly affordable because you're targeting a specific geographic area. Many of our local clients achieve strong results with budgets of &pound;500–&pound;2,000 per month, depending on their industry and service area size.</p>
        </details>
        <details class="faq-item">
          <summary>Do you work with businesses outside Guernsey and Lichfield?</summary>
          <p>Yes — while we're based in Guernsey and Lichfield, we work with local businesses across the UK and Channel Islands. Our local PPC strategies are tailored to your specific service area, whether that's a single town or a broader region.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Dominate Your Local Market?</h2>
      <p>Get a free local visibility audit and discover how many customers you're missing out on.</p>
      <a href="/contact" class="btn btn-white btn-lg">Get Your Free Local Audit</a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does it take to rank in the Google Map Pack?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on your current position, competition, and industry. Most local businesses see meaningful improvements within 2–4 months of consistent optimisation. Highly competitive areas may take longer, but we focus on quick wins first to build momentum."
        }
      },
      {
        "@type": "Question",
        "name": "Do you help with Google Business Profile management?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — Google Business Profile is central to our local SEO service. We handle full setup and ongoing optimisation, including categories, photos, posts, Q&A management, and review response strategy to keep your profile active and competitive."
        }
      },
      {
        "@type": "Question",
        "name": "Can you help us get more customer reviews?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. We implement review generation strategies that make it easy for satisfied customers to leave positive reviews. We also help you respond professionally to all reviews, which builds trust and signals activity to Google."
        }
      },
      {
        "@type": "Question",
        "name": "What budget do local PPC campaigns need?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Local PPC can be surprisingly affordable because you're targeting a specific geographic area. Many of our local clients achieve strong results with budgets of £500–£2,000 per month, depending on their industry and service area size."
        }
      },
      {
        "@type": "Question",
        "name": "Do you work with businesses outside Guernsey and Lichfield?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — while we're based in Guernsey and Lichfield, we work with local businesses across the UK and Channel Islands. Our local PPC strategies are tailored to your specific service area, whether that's a single town or a broader region."
        }
      }
    ]
  })} />
</BaseLayout>

<style>
  .challenge-card { padding: 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius); }
  .challenge-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .challenge-card p { font-size: 0.95rem; color: var(--color-text-light); }
  .process-steps { display: flex; flex-direction: column; gap: 1.5rem; margin: 2rem 0; }
  .step { display: flex; gap: 1.25rem; align-items: start; }
  .step-num { width: 36px; height: 36px; border-radius: 50%; background: var(--color-accent); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; flex-shrink: 0; }
  .step h3 { font-size: 1rem; margin-bottom: 0.25rem; }
  .step p { font-size: 0.92rem; color: var(--color-text-light); }
  .service-link-card { display: block; padding: 1.5rem; background: var(--color-white); border-radius: var(--radius); border: 1px solid var(--color-border); transition: all var(--transition); text-decoration: none; }
  .service-link-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); border-color: var(--color-accent); }
  .service-link-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .service-link-card p { font-size: 0.95rem; color: var(--color-text-light); margin-bottom: 0.75rem; }
  .link-arrow { font-size: 0.9rem; font-weight: 600; color: var(--color-accent); }
  .faq-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
  .faq-item { background: var(--color-white); border-radius: var(--radius-sm); border: 1px solid var(--color-border); overflow: hidden; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--color-accent); font-weight: 700; flex-shrink: 0; margin-left: 1rem; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; font-size: 0.95rem; color: var(--color-text-light); line-height: 1.7; }
</style>

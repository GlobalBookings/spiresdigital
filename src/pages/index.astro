---
import BaseLayout from '../layouts/BaseLayout.astro';
import { caseStudies } from '../data/caseStudies';

const featured = caseStudies.filter(study => ['E-Commerce', 'Retail', 'DTC / E-Commerce'].includes(study.industry)).slice(0, 3);
const faq = [
  { q: 'What kind of ecommerce brands do you work with?', a: 'We are best suited to established or ambitious ecommerce brands that have product-market fit and want clearer unit economics, stronger acquisition performance and a coordinated growth plan.' },
  { q: 'Do we need to use every service?', a: 'No. We start with the constraint that is limiting profitable growth. That may be acquisition, conversion, retention or measurement. The roadmap is joined up, but the engagement can begin with one priority.' },
  { q: 'What happens in the free growth review?', a: 'We review your store, offer, tracking and current channel mix. You receive a concise opportunity map showing the biggest commercial risks, quick wins and recommended next steps.' },
  { q: 'Will we own our advertising and analytics accounts?', a: 'Yes. Your business owns its accounts, data and campaign history. We work inside your systems and keep reporting transparent.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({ '@type': 'Question', name: item.q, acceptedAnswer: { '@type': 'Answer', text: item.a } })),
};
---

<BaseLayout
  title="Home"
  description="Spires Digital is a profit-focused ecommerce growth agency. We connect paid media, SEO, CRO, retention, affiliate and analytics to help brands scale with clarity."
  schema={faqSchema}
>
  <section class="home-hero hero-dark">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="badge">Ecommerce growth, without the guesswork</span>
        <h1>Turn more of your traffic into <em>profitable growth.</em></h1>
        <p>We connect acquisition, conversion, retention and measurement so you know what is working, what is leaking margin and what to fix next.</p>
        <div class="page-hero-actions">
          <a href="/contact" class="btn btn-primary btn-lg btn-arrow" data-track="home_growth_plan">Get your growth plan</a>
          <a href="/tools/ecommerce-profit-calculator" class="btn btn-outline btn-lg" data-track="home_profit_tool">Calculate your break-even ROAS</a>
        </div>
        <ul class="hero-checks">
          <li>No lock-in contracts</li>
          <li>You own every account</li>
          <li>Profit before platform vanity metrics</li>
        </ul>
      </div>

      <div class="growth-console" aria-label="Illustrative ecommerce growth dashboard">
        <div class="console-head"><span>Growth opportunity map</span><span class="live-dot">Live priorities</span></div>
        <div class="score-card">
          <div><span>Profitability readiness</span><strong>72<span>/100</span></strong></div>
          <svg viewBox="0 0 120 60" role="img" aria-label="Upward growth trend"><path d="M2 51 C21 47 26 34 44 38 S69 25 80 28 S100 11 118 7" fill="none" stroke="#75e6d3" stroke-width="4" stroke-linecap="round"/><path d="M2 51 C21 47 26 34 44 38 S69 25 80 28 S100 11 118 7 L118 60 L2 60Z" fill="url(#fade)" opacity=".35"/><defs><linearGradient id="fade" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#75e6d3"/><stop offset="1" stop-color="#75e6d3" stop-opacity="0"/></linearGradient></defs></svg>
        </div>
        <div class="priority-list">
          <div><span class="priority-num">01</span><p><strong>Protect contribution margin</strong><small>Set channel targets from real costs</small></p><span class="impact high">High impact</span></div>
          <div><span class="priority-num">02</span><p><strong>Lift product-page CVR</strong><small>Fix trust and offer friction</small></p><span class="impact">+18% modelled</span></div>
          <div><span class="priority-num">03</span><p><strong>Recover repeat revenue</strong><small>Improve post-purchase journeys</small></p><span class="impact">Next</span></div>
        </div>
        <p class="console-note">Illustrative output from our ecommerce growth assessment.</p>
      </div>
    </div>
  </section>

  <section class="proof-strip surface">
    <div class="container proof-grid">
      <div><strong>15+</strong><span>years in digital growth</span></div>
      <div><strong>£10m+</strong><span>advertising spend managed</span></div>
      <div><strong>150+</strong><span>campaigns delivered</span></div>
      <div class="proof-partners">
        <span>Certified and recognised by</span>
        <div>
          <img src="/images/partners/shopify-partner.jpg" alt="Shopify Partner" width="110" height="48" loading="lazy" />
          <img src="/images/partners/awin-certified.png" alt="AWIN Certified Agency" width="110" height="48" loading="lazy" />
          <img src="/images/partners/meta-business-partner.avif" alt="Meta Business Partner" width="110" height="48" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="section surface-warm">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">The real ecommerce problem</span>
        <h2>More revenue does not always mean more profit.</h2>
        <p>Channel dashboards reward spend and attributed revenue. Your business needs a joined-up view of margin, conversion, repeat purchase and cash efficiency.</p>
      </div>
      <div class="problem-grid">
        <article><span>01</span><h3>Acquisition gets more expensive</h3><p>Rising CPCs and CPMs expose weak offers, poor feeds and arbitrary ROAS targets.</p></article>
        <article><span>02</span><h3>Traffic leaks before checkout</h3><p>Slow journeys, unclear product value and missing trust signals quietly cap every channel.</p></article>
        <article><span>03</span><h3>Retention is treated separately</h3><p>Without lifecycle journeys, paid acquisition keeps buying customers you should be earning back.</p></article>
        <article><span>04</span><h3>Attribution hides the answer</h3><p>Platforms claim the same sale while fees, returns and fulfilment disappear from the story.</p></article>
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="container">
      <div class="section-heading center">
        <span class="eyebrow">One commercial growth system</span>
        <h2>Acquire. Convert. Retain. Measure.</h2>
        <p>Each discipline has a clear job. Together, they create a system that can scale without losing sight of profit.</p>
      </div>
      <div class="growth-system">
        <article class="system-card acquire">
          <span class="system-index">01 / Acquire</span><h3>Find profitable demand</h3><p>Google Shopping, paid search, Meta, affiliate and ecommerce SEO coordinated around commercial intent.</p>
          <div class="pill-row"><span class="pill">Google Ads</span><span class="pill">Meta</span><span class="pill">SEO</span><span class="pill">Affiliate</span></div>
          <a href="/services#acquire" class="text-link">Explore acquisition →</a>
        </article>
        <article class="system-card convert">
          <span class="system-index">02 / Convert</span><h3>Make every session work harder</h3><p>Research-led CRO, product-page improvements, Shopify development and rapid landing-page tests.</p>
          <div class="pill-row"><span class="pill">CRO</span><span class="pill">Shopify</span><span class="pill">Landing pages</span></div>
          <a href="/services/cro-shopify" class="text-link">Explore conversion →</a>
        </article>
        <article class="system-card retain">
          <span class="system-index">03 / Retain</span><h3>Earn the next purchase</h3><p>Lifecycle email, segmentation and customer journeys that increase repeat rate and reduce paid dependency.</p>
          <div class="pill-row"><span class="pill">Email</span><span class="pill">Automation</span><span class="pill">LTV</span></div>
          <a href="/services/email-retention" class="text-link">Explore retention →</a>
        </article>
        <article class="system-card measure">
          <span class="system-index">04 / Measure</span><h3>Scale what creates profit</h3><p>Clean tracking, blended reporting, contribution-margin targets and decisions the whole team can understand.</p>
          <div class="pill-row"><span class="pill">GA4</span><span class="pill">Attribution</span><span class="pill">Profit</span></div>
          <a href="/services/analytics-attribution" class="text-link">Explore measurement →</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section tools-feature">
    <div class="container split">
      <div class="split-copy">
        <span class="eyebrow">Free ecommerce tools</span>
        <h2>Use your numbers before you spend another pound.</h2>
        <p>Our calculators turn store economics into practical targets. No login, no spreadsheet and no email required.</p>
        <ul class="check-list tool-list">
          <li><a href="/tools/ecommerce-profit-calculator"><strong>Profit &amp; break-even ROAS calculator</strong><span>Find your true acquisition ceiling.</span></a></li>
          <li><a href="/tools/channel-budget-planner"><strong>Channel budget planner</strong><span>Model the traffic and spend behind a revenue target.</span></a></li>
          <li><a href="/tools/growth-assessment"><strong>Store growth assessment</strong><span>Find the next constraint to remove.</span></a></li>
          <li><a href="/tools/google-ads-audit-checklist"><strong>Google Ads audit checklist</strong><span>Prioritise the account control to validate first.</span></a></li>
        </ul>
        <a href="/tools" class="btn btn-primary btn-arrow">Explore every free tool</a>
      </div>
      <div class="calculator-preview">
        <div class="preview-head"><span>Your profit target</span><span>Scenario A</span></div>
        <div class="preview-metric"><small>Break-even ROAS</small><strong>2.34×</strong><span>Minimum before profit</span></div>
        <div class="margin-bar" aria-hidden="true"><span class="cogs" style="width:42%"></span><span class="ops" style="width:19%"></span><span class="ads" style="width:26%"></span><span class="profit" style="width:13%"></span></div>
        <div class="margin-key"><span><i class="cogs"></i>COGS 42%</span><span><i class="ops"></i>Operations 19%</span><span><i class="ads"></i>Ads 26%</span><span><i class="profit"></i>Profit 13%</span></div>
        <div class="preview-row"><span>Target ROAS</span><strong>2.91×</strong></div>
        <div class="preview-row"><span>Maximum CAC</span><strong>£34.80</strong></div>
        <div class="preview-row"><span>Target MER</span><strong>34.4%</strong></div>
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Selected outcomes</span>
        <h2>Work measured against commercial results.</h2>
        <p>Client identities are anonymised where commercial agreements require it. Each result reflects an individual engagement, not a promise of future performance.</p>
      </div>
      <div class="results-grid">
        {featured.map(study => (
          <article class="result-card">
            <div class="result-top"><span>{study.industry}</span><span>{study.service}</span></div>
            <h3>{study.title}</h3>
            <p>{study.challenge}</p>
            <div class="result-metrics">
              {study.stats.map(stat => <div><strong>{stat.value}</strong><span>{stat.label}</span></div>)}
            </div>
          </article>
        ))}
      </div>
      <div class="section-action"><a href="/case-studies" class="btn btn-secondary btn-arrow">See how the work was approached</a></div>
    </div>
  </section>

  <section class="section surface-warm">
    <div class="container split process-split">
      <div class="split-copy">
        <span class="eyebrow">A useful first conversation</span>
        <h2>Start with the constraint, not a channel pitch.</h2>
        <p>Your free growth review is designed to identify where profit is being lost and which change has the strongest commercial case.</p>
        <a href="/how-we-work" class="text-link">See the full working process →</a>
      </div>
      <ol class="mini-process">
        <li><span>1</span><div><strong>Share the context</strong><p>Store, targets, current channels and the problem you are trying to solve.</p></div></li>
        <li><span>2</span><div><strong>We review the journey</strong><p>Acquisition, merchandising, conversion, retention and measurement.</p></div></li>
        <li><span>3</span><div><strong>Receive an opportunity map</strong><p>Clear priorities, likely impact, dependencies and recommended next step.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="section surface">
    <div class="container-narrow">
      <div class="section-heading center"><span class="eyebrow">Common questions</span><h2>Before we talk.</h2></div>
      <div class="faq-list">
        {faq.map(item => <details><summary>{item.q}</summary><p>{item.a}</p></details>)}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <span class="badge">Your next profitable move</span>
      <h2>Find the clearest opportunity in your ecommerce journey.</h2>
      <p>Tell us what you are working towards. We will turn the context into a practical growth plan.</p>
      <a href="/contact" class="btn btn-white btn-lg btn-arrow" data-track="home_final_growth_plan">Get your free growth plan</a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero { padding-top: clamp(8rem, 13vw, 11rem); }
  .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(2.5rem, 6vw, 5.5rem); align-items: center; }
  .hero-copy h1 { max-width: 750px; }
  .hero-copy h1 em { color: #91eadb; font-style: normal; }
  .hero-copy > p { max-width: 670px; }
  .hero-checks { display: flex; flex-wrap: wrap; gap: .7rem 1.3rem; margin-top: 1.6rem; color: #d7ddea; font-size: .78rem; list-style: none; }
  .hero-checks li::before { margin-right: .4rem; color: #75e6d3; content: '✓'; font-weight: 800; }
  .growth-console { padding: 1rem; border: 1px solid rgba(255,255,255,.14); border-radius: 22px; background: rgba(255,255,255,.075); box-shadow: 0 30px 80px rgba(0,0,0,.25); backdrop-filter: blur(10px); }
  .console-head, .preview-head { display: flex; justify-content: space-between; padding: .45rem .4rem 1rem; color: #cbd2df; font-size: .72rem; font-weight: 700; }
  .live-dot { color: #91eadb; }
  .live-dot::before { display: inline-block; width: 7px; height: 7px; margin-right: .4rem; border-radius: 50%; background: #75e6d3; content: ''; box-shadow: 0 0 0 4px rgba(117,230,211,.12); }
  .score-card { display: grid; grid-template-columns: 1fr 1.1fr; align-items: end; padding: 1.2rem; border-radius: 14px; background: #151f35; }
  .score-card > div > span { display: block; color: #9da8ba; font-size: .7rem; }
  .score-card strong { display: block; margin-top: .35rem; color: white; font-size: 2.4rem; letter-spacing: -.06em; }
  .score-card strong span { color: #8490a4; font-size: .85rem; }
  .score-card svg { width: 100%; }
  .priority-list { display: grid; gap: .55rem; margin-top: .65rem; }
  .priority-list > div { display: grid; grid-template-columns: auto 1fr auto; gap: .7rem; align-items: center; padding: .8rem; border-radius: 11px; background: rgba(255,255,255,.075); }
  .priority-num { display: grid; width: 30px; height: 30px; place-items: center; border-radius: 8px; background: rgba(117,230,211,.12); color: #91eadb; font-size: .66rem; font-weight: 800; }
  .priority-list p { margin: 0; line-height: 1.2; }
  .priority-list strong { display: block; color: white; font-size: .78rem; }
  .priority-list small { color: #9da8ba; font-size: .64rem; }
  .impact { padding: .3rem .45rem; border-radius: 999px; background: rgba(255,255,255,.08); color: #cbd2df; font-size: .58rem; font-weight: 800; }
  .impact.high { background: rgba(117,230,211,.12); color: #91eadb; }
  .console-note { margin: .7rem .3rem 0 !important; color: #7f8ba0 !important; font-size: .62rem !important; }

  .proof-strip { padding: 1.6rem 0; border-bottom: 1px solid var(--line); }
  .proof-grid { display: grid; grid-template-columns: repeat(3, auto) 1fr; gap: 1.5rem; align-items: center; }
  .proof-grid > div:not(.proof-partners) { padding-right: 1.5rem; border-right: 1px solid var(--line); }
  .proof-grid strong { display: block; color: var(--ink); font-size: 1.35rem; letter-spacing: -.04em; }
  .proof-grid span { color: var(--slate); font-size: .67rem; }
  .proof-partners { justify-self: end; text-align: right; }
  .proof-partners > div { display: flex; gap: 1rem; align-items: center; margin-top: .35rem; }
  .proof-partners img { width: auto; max-width: 90px; height: 34px; object-fit: contain; filter: grayscale(1); opacity: .65; }

  .problem-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .problem-grid article { min-height: 250px; padding: 1.6rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .problem-grid article > span { color: var(--violet-dark); font-size: .72rem; font-weight: 800; }
  .problem-grid h3 { margin: 2.6rem 0 .75rem; }
  .problem-grid p { color: var(--slate); font-size: .88rem; }

  .growth-system { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .system-card { min-height: 330px; padding: clamp(1.5rem, 3vw, 2.3rem); border: 1px solid var(--line); border-radius: var(--radius); background: var(--canvas); }
  .system-index { color: var(--violet-dark); font-size: .72rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .system-card h3 { margin: 3.2rem 0 .8rem; font-size: clamp(1.7rem, 3vw, 2.5rem); }
  .system-card > p { max-width: 520px; color: var(--slate); }
  .system-card .pill-row { margin: 1.3rem 0; }
  .system-card.acquire { background: #f0f0ff; }
  .system-card.convert { background: #eef9f6; }
  .system-card.retain { background: #fff7eb; }
  .system-card.measure { background: #eef3f9; }

  .tools-feature { background: #e9e8ff; }
  .tool-list { margin: 1.8rem 0; }
  .tool-list a { display: grid; }
  .tool-list span { color: var(--slate); font-size: .82rem; }
  .calculator-preview { padding: 1.2rem; border-radius: 22px; background: var(--ink); box-shadow: var(--shadow-lg); color: white; }
  .preview-head { border-bottom: 1px solid rgba(255,255,255,.12); }
  .preview-metric { padding: 1.5rem .4rem; }
  .preview-metric small { display: block; color: #98a4b8; }
  .preview-metric strong { display: block; margin: .25rem 0; font-size: 3.6rem; letter-spacing: -.07em; }
  .preview-metric span { color: #91eadb; font-size: .75rem; }
  .margin-bar { display: flex; height: 18px; overflow: hidden; border-radius: 999px; }
  .margin-bar span { display: block; height: 100%; }
  .cogs { background: #7772f4; }.ops { background: #9da8ba; }.ads { background: #38c6ae; }.profit { background: #f3b958; }
  .margin-key { display: flex; flex-wrap: wrap; gap: .5rem .8rem; margin: .7rem 0 1.3rem; color: #aab4c5; font-size: .58rem; }
  .margin-key i { display: inline-block; width: 7px; height: 7px; margin-right: .3rem; border-radius: 50%; }
  .preview-row { display: flex; justify-content: space-between; padding: .8rem .35rem; border-top: 1px solid rgba(255,255,255,.1); color: #aab4c5; font-size: .78rem; }
  .preview-row strong { color: white; font-size: .9rem; }

  .results-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .result-card { display: flex; min-height: 390px; flex-direction: column; padding: 1.5rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--canvas); }
  .result-top { display: flex; justify-content: space-between; color: var(--muted); font-size: .68rem; font-weight: 700; }
  .result-card h3 { margin: 2.4rem 0 .8rem; }
  .result-card > p { color: var(--slate); font-size: .84rem; }
  .result-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: .5rem; margin-top: auto; padding-top: 1.5rem; border-top: 1px solid var(--line); }
  .result-metrics strong, .result-metrics span { display: block; }
  .result-metrics strong { color: var(--violet-dark); font-size: 1.25rem; letter-spacing: -.04em; }
  .result-metrics span { color: var(--muted); font-size: .58rem; line-height: 1.25; }
  .section-action { margin-top: 1.5rem; text-align: center; }

  .mini-process { display: grid; gap: .8rem; list-style: none; }
  .mini-process li { display: grid; grid-template-columns: auto 1fr; gap: 1rem; padding: 1.2rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: white; }
  .mini-process li > span { display: grid; width: 36px; height: 36px; place-items: center; border-radius: 50%; background: var(--ink); color: white; font-size: .72rem; font-weight: 800; }
  .mini-process strong { color: var(--ink); }
  .mini-process p { margin-top: .25rem; color: var(--slate); font-size: .83rem; }
  .faq-list { display: grid; gap: .7rem; }
  .faq-list details { border: 1px solid var(--line); border-radius: var(--radius-sm); background: white; }
  .faq-list summary { display: flex; justify-content: space-between; padding: 1.2rem; cursor: pointer; color: var(--ink); font-weight: 750; list-style: none; }
  .faq-list summary::after { color: var(--violet-dark); content: '+'; }
  .faq-list details[open] summary::after { content: '−'; }
  .faq-list details p { padding: 0 1.2rem 1.2rem; color: var(--slate); }

  @media (max-width: 980px) {
    .hero-grid { grid-template-columns: 1fr; }
    .growth-console { max-width: 650px; }
    .proof-grid { grid-template-columns: repeat(3, 1fr); }
    .proof-partners { grid-column: 1 / -1; justify-self: start; text-align: left; }
    .problem-grid { grid-template-columns: repeat(2, 1fr); }
    .results-grid { grid-template-columns: 1fr; }
    .result-card { min-height: auto; }
    .result-metrics { margin-top: 2rem; }
  }
  @media (max-width: 680px) {
    .home-hero { padding-top: 7.5rem; }
    .hero-checks { display: grid; }
    .growth-console { padding: .7rem; }
    .priority-list > div { grid-template-columns: auto 1fr; }
    .impact { display: none; }
    .proof-grid { grid-template-columns: 1fr 1fr; }
    .proof-grid > div:not(.proof-partners) { padding: .7rem; border: 0; }
    .problem-grid, .growth-system { grid-template-columns: 1fr; }
    .problem-grid article { min-height: 220px; }
    .result-metrics { grid-template-columns: repeat(3, 1fr); }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const tools = [
  { href: '/tools/ecommerce-profit-calculator', label: 'Profit', title: 'Ecommerce profit & break-even ROAS calculator', text: 'Calculate the ROAS, MER, CAC and advertising budget your full cost structure can support.', cta: 'Calculate profit targets' },
  { href: '/tools/channel-budget-planner', label: 'Plan', title: 'Ecommerce channel budget planner', text: 'Work backwards from a revenue goal to the orders, traffic and channel budget required.', cta: 'Build a budget scenario' },
  { href: '/tools/growth-assessment', label: 'Diagnose', title: 'Store growth assessment', text: 'Identify whether acquisition, conversion, retention or measurement is the likely current constraint.', cta: 'Assess the store' },
  { href: '/tools/google-ads-vat-guide', label: 'UK guidance', title: 'Google Ads VAT decision guide', text: 'Understand which billing and business details to check before discussing Google Ads VAT with your accountant.', cta: 'Check the decision path' },
  { href: '/tools/paid-media-waste-estimator', label: 'Efficiency', title: 'Paid media waste estimator', text: 'Estimate the value of fixing weak tracking, search-term control, feed quality and landing-page conversion.', cta: 'Estimate the opportunity' },
  { href: '/seo-keyword-density-checker', label: 'Content', title: 'Keyword density & content analyser', text: 'Check word count, repeated language, target-phrase usage and the terms that dominate a draft—without uploading it.', cta: 'Analyse content' },
];
---
<BaseLayout title="Free Ecommerce Growth Tools" description="Free browser-based ecommerce calculators and tools for profit, ROAS, channel budgets, store growth, content analysis, Google Ads VAT and paid media efficiency.">
  <div class="breadcrumbs-wrap"><Breadcrumbs items={[{ label: 'Free tools' }]} /></div>
  <section class="page-hero"><div class="container page-hero-content"><span class="badge">Free ecommerce tools</span><h1>Make the next decision with your own numbers.</h1><p>Useful calculators and diagnostics built for ecommerce operators. No login, no spreadsheet download and no email gate.</p></div></section>
  <section class="tool-jobs surface"><div class="container"><div><span class="eyebrow">Choose the job</span><h2>Start with the decision in front of you.</h2><p>Each tool creates an immediate result you can copy, print or voluntarily carry into a consultation.</p></div><nav aria-label="Choose a tool by job"><a href="/tools/ecommerce-profit-calculator"><span>Set guardrails</span><strong>How much can we afford to spend?</strong></a><a href="/tools/channel-budget-planner"><span>Build a plan</span><strong>What would the revenue target require?</strong></a><a href="/tools/growth-assessment"><span>Find a constraint</span><strong>Where should we investigate first?</strong></a><a href="/tools/paid-media-waste-estimator"><span>Audit efficiency</span><strong>Which media controls need evidence?</strong></a><a href="/seo-keyword-density-checker"><span>Review a draft</span><strong>Where does the wording feel repetitive?</strong></a><a href="/tools/google-ads-vat-guide"><span>Check billing</span><strong>Which tax facts and documents matter?</strong></a></nav></div></section>
  <section class="section surface"><div class="container tools-grid">{tools.map((tool,index)=><a href={tool.href} class:list={['tool-link',{featured:index===0}]}><span class="tool-label">{tool.label}</span><span class="tool-index">0{index+1}</span><h2>{tool.title}</h2><p>{tool.text}</p><strong>{tool.cta} →</strong></a>)}</div></section>
  <section class="section tools-principles"><div class="container split"><div><span class="eyebrow">Why these tools exist</span><h2>Better first conversations start with commercial clarity.</h2></div><div class="principles"><div><strong>Useful before sales</strong><p>Every result is available immediately. Contact details are optional and separate.</p></div><div><strong>Transparent assumptions</strong><p>The formula and limitations are explained so the output can be challenged.</p></div><div><strong>Built for action</strong><p>Each result identifies a decision or next investigation, not only a score.</p></div></div></div></section>
  <section class="cta-section"><div class="container"><h2>A calculator gives you a target. A review gives it context.</h2><p>Share the result and the commercial situation when you want help deciding what to change.</p><a href="/contact" class="btn btn-white btn-lg btn-arrow">Get a free growth review</a></div></section>
</BaseLayout>
<style>.tool-jobs{padding:2.2rem 0;border-bottom:1px solid var(--line)}.tool-jobs .container{display:grid;grid-template-columns:.55fr 1fr;gap:2rem;align-items:start}.tool-jobs h2{margin:.45rem 0;font-size:clamp(1.7rem,3vw,2.4rem)}.tool-jobs p{color:var(--slate);font-size:.8rem}.tool-jobs nav{display:grid;grid-template-columns:repeat(2,1fr);gap:.55rem}.tool-jobs a{padding:.85rem;border:1px solid var(--line);border-radius:10px;background:var(--canvas)}.tool-jobs a:hover{border-color:var(--violet)}.tool-jobs a span,.tool-jobs a strong{display:block}.tool-jobs a span{color:var(--violet-dark);font-size:.62rem;font-weight:800;text-transform:uppercase}.tool-jobs a strong{margin-top:.25rem;color:var(--ink);font-size:.76rem}.tools-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}.tool-link{position:relative;min-height:330px;padding:1.6rem;border:1px solid var(--line);border-radius:var(--radius);background:var(--canvas);transition:transform var(--transition),box-shadow var(--transition)}.tool-link:hover{transform:translateY(-4px);box-shadow:var(--shadow)}.tool-link.featured{grid-column:1/-1;min-height:370px;background:#e9e8ff}.tool-label{color:var(--violet-dark);font-size:.68rem;font-weight:800;text-transform:uppercase}.tool-index{position:absolute;top:1.6rem;right:1.6rem;color:var(--muted);font-size:.68rem;font-weight:800}.tool-link h2{max-width:700px;margin:4rem 0 1rem;font-size:clamp(1.6rem,3vw,2.6rem)}.tool-link p{max-width:660px;color:var(--slate)}.tool-link strong{display:block;margin-top:1.4rem;color:var(--violet-dark);font-size:.78rem}.tools-principles{background:#e9e8ff}.principles{display:grid;gap:.7rem}.principles>div{padding:1.1rem;border-radius:var(--radius-sm);background:white}.principles strong{color:var(--ink)}.principles p{margin-top:.3rem;color:var(--slate);font-size:.8rem}@media(max-width:800px){.tool-jobs .container{grid-template-columns:1fr}}@media(max-width:700px){.tools-grid,.tool-jobs nav{grid-template-columns:1fr}.tool-link.featured{grid-column:auto}}</style>

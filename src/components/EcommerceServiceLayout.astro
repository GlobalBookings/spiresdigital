---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';

interface FAQ { q: string; a: string; }
interface Props {
  title: string;
  metaTitle: string;
  description: string;
  phase: string;
  intro: string;
  promise: string;
  outcomes: { value: string; label: string }[];
  problems: { title: string; text: string }[];
  deliverables: { title: string; text: string }[];
  process: { title: string; text: string }[];
  fit: string[];
  faqs: FAQ[];
  related: { href: string; label: string }[];
}

const { title, metaTitle, description, phase, intro, promise, outcomes, problems, deliverables, process, fit, faqs, related } = Astro.props;
const pricingFaq: FAQ = {
  q: 'How much does this service cost?',
  a: 'We price every engagement after an initial consultation. The right scope depends on your current setup, goals, data quality, platform complexity and who will implement the work. Once those are clear, we provide a written scope and price before anything begins.',
};
const allFaqs = [...faqs, pricingFaq];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description,
  provider: { '@id': 'https://spiresdigital.com/#organisation' },
  areaServed: ['United Kingdom', 'Guernsey', 'Europe'],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqs.map(item => ({ '@type': 'Question', name: item.q, acceptedAnswer: { '@type': 'Answer', text: item.a } })),
};
---

<BaseLayout title={metaTitle} description={description} schema={[serviceSchema, faqSchema]}>
  <div class="breadcrumbs-wrap"><Breadcrumbs items={[{ label: 'Services', href: '/services' }, { label: title }]} /></div>
  <section class="service-hero hero-dark">
    <div class="container service-hero-grid">
      <div>
        <span class="badge">{phase}</span>
        <h1>{title}</h1>
        <p>{intro}</p>
        <div class="page-hero-actions">
          <a href="/contact" class="btn btn-primary btn-lg btn-arrow" data-track={`service_${phase.toLowerCase()}_plan`}>Get a tailored growth plan</a>
          <a href="/case-studies" class="btn btn-outline btn-lg">See selected outcomes</a>
        </div>
      </div>
      <aside class="promise-card">
        <span>Commercial promise</span>
        <h2>{promise}</h2>
        <ul class="check-list"><li>You own every account and asset</li><li>Targets are tied to commercial economics</li><li>Clear priorities and plain-English reporting</li></ul>
      </aside>
    </div>
  </section>

  <section class="outcome-strip surface">
    <div class="container outcome-grid">
      {outcomes.map(outcome => <div><strong>{outcome.value}</strong><span>{outcome.label}</span></div>)}
    </div>
  </section>

  <section class="section surface-warm">
    <div class="container">
      <div class="section-heading"><span class="eyebrow">Where growth gets stuck</span><h2>The problems this work is designed to solve.</h2></div>
      <div class="problem-cards">
        {problems.map((problem, index) => <article><span>0{index + 1}</span><h3>{problem.title}</h3><p>{problem.text}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="container">
      <div class="section-heading"><span class="eyebrow">What is included</span><h2>A practical system, not disconnected activity.</h2></div>
      <div class="deliverable-grid">
        {deliverables.map((item, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><div><h3>{item.title}</h3><p>{item.text}</p></div></article>)}
      </div>
    </div>
  </section>

  <section class="section process-section">
    <div class="container split">
      <div class="split-copy"><span class="eyebrow">How the work moves</span><h2>From evidence to repeatable improvement.</h2><p>Every engagement starts with the current commercial reality. The channel comes after the diagnosis.</p></div>
      <ol class="service-process">
        {process.map((step, index) => <li><span>{index + 1}</span><div><h3>{step.title}</h3><p>{step.text}</p></div></li>)}
      </ol>
    </div>
  </section>

  <section class="section surface">
    <div class="container fit-grid">
      <div><span class="eyebrow">A strong fit when</span><h2>This is likely to be useful if…</h2></div>
      <ul class="check-list fit-list">{fit.map(item => <li>{item}</li>)}</ul>
    </div>
  </section>

  <section class="pricing-section surface">
    <div class="container pricing-card">
      <div><span class="eyebrow">Pricing</span><h2>Understand the work first. Price it properly second.</h2></div>
      <div><p>We do not use a public rate card. We start with a consultation to understand the commercial goal, current setup, platform, data and delivery requirements. If there is a strong fit, you receive a clear written scope and price before deciding whether to proceed.</p><a href="/contact" class="btn btn-secondary btn-arrow" data-track="service_pricing_consultation">Book a pricing consultation</a></div>
    </div>
  </section>

  <section class="section surface-warm">
    <div class="container-narrow">
      <div class="section-heading center"><span class="eyebrow">Questions</span><h2>What brands usually ask.</h2></div>
      <div class="service-faq">{allFaqs.map(item => <details><summary>{item.q}</summary><p>{item.a}</p></details>)}</div>
    </div>
  </section>

  <section class="related surface"><div class="container"><span>Works well alongside</span><div>{related.map(item => <a href={item.href}>{item.label} <span aria-hidden="true">→</span></a>)}</div></div></section>
  <section class="cta-section"><div class="container"><span class="badge">Start with the numbers</span><h2>Find the clearest next move for your store.</h2><p>Share the context and we will return a focused opportunity map—not a generic channel pitch.</p><a href="/contact" class="btn btn-white btn-lg btn-arrow" data-track="service_final_plan">Get your free growth plan</a></div></section>
</BaseLayout>

<style>
  .service-hero { padding-top: 5rem; }
  .service-hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.1fr .7fr; gap: clamp(2.5rem, 7vw, 6rem); align-items: center; }
  .service-hero h1 { max-width: 800px; }
  .promise-card { padding: clamp(1.4rem, 3vw, 2rem); border: 1px solid rgba(255,255,255,.15); border-radius: var(--radius); background: rgba(255,255,255,.07); }
  .promise-card > span { color: #91eadb; font-size: .7rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .promise-card h2 { margin: 1rem 0 1.5rem; color: white; font-size: clamp(1.5rem, 3vw, 2.2rem); }
  .promise-card .check-list { color: #d7ddea; font-size: .8rem; }
  .outcome-strip { padding: 1.6rem 0; border-bottom: 1px solid var(--line); }
  .outcome-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  .outcome-grid > div { padding: .5rem 1.5rem; border-right: 1px solid var(--line); }
  .outcome-grid > div:last-child { border: 0; }
  .outcome-grid strong, .outcome-grid span { display: block; }
  .outcome-grid strong { color: var(--ink); font-size: 1.05rem; }
  .outcome-grid span { margin-top: .2rem; color: var(--slate); font-size: .72rem; }
  .problem-cards { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .problem-cards article { min-height: 290px; padding: 1.5rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .problem-cards article > span { color: var(--violet-dark); font-size: .7rem; font-weight: 800; }
  .problem-cards h3 { margin: 3rem 0 .8rem; }
  .problem-cards p, .deliverable-grid p { color: var(--slate); font-size: .88rem; }
  .deliverable-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .deliverable-grid article { display: grid; grid-template-columns: auto 1fr; gap: 1rem; padding: 1.4rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--canvas); }
  .deliverable-grid article > span { display: grid; width: 34px; height: 34px; place-items: center; border-radius: 9px; background: var(--violet-soft); color: var(--violet-dark); font-size: .7rem; font-weight: 800; }
  .deliverable-grid h3 { margin-bottom: .5rem; font-size: 1.08rem; }
  .process-section { background: #e9e8ff; }
  .service-process { display: grid; gap: .7rem; list-style: none; }
  .service-process li { display: grid; grid-template-columns: auto 1fr; gap: 1rem; padding: 1.2rem; border-radius: var(--radius-sm); background: white; }
  .service-process li > span { display: grid; width: 34px; height: 34px; place-items: center; border-radius: 50%; background: var(--ink); color: white; font-size: .7rem; font-weight: 800; }
  .service-process h3 { font-size: 1rem; }
  .service-process p { margin-top: .25rem; color: var(--slate); font-size: .8rem; }
  .fit-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: 4rem; align-items: start; }
  .fit-list { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .fit-list li { padding: 1rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--canvas); }
  .pricing-section { padding: 0 0 clamp(4rem, 8vw, 7rem); }
  .pricing-card { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(2rem, 7vw, 6rem); align-items: center; padding: clamp(1.5rem, 4vw, 2.5rem); border: 1px solid var(--line); border-radius: var(--radius); background: var(--canvas); }
  .pricing-card h2 { margin-top: .7rem; font-size: clamp(1.55rem, 3vw, 2.25rem); }
  .pricing-card p { margin-bottom: 1.2rem; color: var(--slate); }
  .service-faq { display: grid; gap: .7rem; }
  .service-faq details { border: 1px solid var(--line); border-radius: var(--radius-sm); background: white; }
  .service-faq summary { display: flex; justify-content: space-between; padding: 1.2rem; cursor: pointer; color: var(--ink); font-weight: 750; list-style: none; }
  .service-faq summary::after { color: var(--violet-dark); content: '+'; }
  .service-faq details[open] summary::after { content: '−'; }
  .service-faq p { padding: 0 1.2rem 1.2rem; color: var(--slate); }
  .related { padding: 2rem 0; border-top: 1px solid var(--line); }
  .related .container { display: flex; justify-content: space-between; gap: 1rem; align-items: center; }
  .related .container > span { color: var(--muted); font-size: .72rem; font-weight: 800; text-transform: uppercase; }
  .related .container > div { display: flex; flex-wrap: wrap; gap: .7rem; }
  .related a { padding: .55rem .8rem; border: 1px solid var(--line); border-radius: 999px; font-size: .74rem; font-weight: 700; }
  .related a:hover { border-color: var(--violet); color: var(--violet-dark); }
  @media (max-width: 900px) { .service-hero-grid, .fit-grid, .pricing-card { grid-template-columns: 1fr; } .problem-cards { grid-template-columns: 1fr; } }
  @media (max-width: 680px) { .outcome-grid, .deliverable-grid, .fit-list { grid-template-columns: 1fr; } .outcome-grid > div { border-right: 0; border-bottom: 1px solid var(--line); } .related .container { align-items: flex-start; flex-direction: column; } }
</style>

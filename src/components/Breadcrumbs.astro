---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const allItems = [{ label: 'Home', href: '/' }, ...items];
---

<nav class="breadcrumbs container" aria-label="Breadcrumb">
  <ol>
    {allItems.map((item, i) => (
      <li>
        {item.href && i < allItems.length - 1
          ? <a href={item.href}>{item.label}</a>
          : <span>{item.label}</span>
        }
        {i < allItems.length - 1 && <span class="sep">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs { padding-top: 6rem; padding-bottom: 0.5rem; }
  ol { display: flex; flex-wrap: wrap; list-style: none; gap: 0.25rem; font-size: 0.85rem; }
  a { color: var(--color-accent); }
  a:hover { text-decoration: underline; }
  span { color: var(--color-text-light); }
  .sep { margin: 0 0.25rem; opacity: 0.4; }
</style>

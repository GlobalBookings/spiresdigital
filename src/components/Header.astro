---
const pathname = Astro.url.pathname;
const servicesOpen = pathname.startsWith('/services');
---

<header class="site-header" id="site-header">
  <nav class="container header-inner" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="Spires Digital home">
      <img src="/logo.png" alt="Spires Digital" width="175" height="58" />
    </a>

    <button class="menu-toggle" id="menu-toggle" type="button" aria-controls="primary-nav" aria-expanded="false">
      <span class="sr-only">Open menu</span>
      <span></span><span></span><span></span>
    </button>

    <div class="nav-shell" id="primary-nav">
      <ul class="nav-links">
        <li><a href="/industries/ecommerce" class:list={[{ active: pathname.startsWith('/industries/ecommerce') }]}>Ecommerce growth</a></li>
        <li>
          <details class="nav-dropdown" open={servicesOpen ? undefined : false}>
            <summary class:list={[{ active: servicesOpen }]}>Services <span aria-hidden="true">⌄</span></summary>
            <div class="dropdown-panel">
              <a href="/services"><strong>All services</strong><span>See the complete growth system</span></a>
              <a href="/services/ppc-management"><strong>Google Shopping &amp; PPC</strong><span>Capture high-intent demand</span></a>
              <a href="/services/meta-ads"><strong>Meta ads</strong><span>Creative-led customer acquisition</span></a>
              <a href="/services/ecommerce-seo"><strong>Ecommerce SEO</strong><span>Compound non-paid growth</span></a>
              <a href="/services/cro-shopify"><strong>CRO &amp; Shopify</strong><span>Turn more sessions into sales</span></a>
              <a href="/services/email-retention"><strong>Email &amp; retention</strong><span>Grow repeat-purchase revenue</span></a>
              <a href="/services/affiliate-management"><strong>Affiliate growth</strong><span>Scale partner-led revenue</span></a>
              <a href="/services/analytics-attribution"><strong>Analytics &amp; attribution</strong><span>Know what is actually profitable</span></a>
            </div>
          </details>
        </li>
        <li><a href="/case-studies" class:list={[{ active: pathname.startsWith('/case-studies') }]}>Results</a></li>
        <li><a href="/tools" class:list={[{ active: pathname.startsWith('/tools') }]}>Free tools</a></li>
        <li><a href="/blog" class:list={[{ active: pathname.startsWith('/blog') }]}>Insights</a></li>
        <li><a href="/about" class:list={[{ active: pathname === '/about' }]}>About</a></li>
      </ul>
      <a href="/contact" class="btn btn-primary nav-cta" data-track="header_growth_plan">Get a growth plan</a>
    </div>
  </nav>
</header>

<style>
  .site-header { position: fixed; inset: 0 0 auto; z-index: 1000; border-bottom: 1px solid rgba(223,228,236,.9); background: rgba(255,255,255,.92); backdrop-filter: blur(16px); }
  .header-inner { display: flex; min-height: 84px; align-items: center; justify-content: space-between; gap: 1.3rem; }
  .logo { flex: 0 0 auto; }
  .logo img { width: 156px; height: auto; }
  .nav-shell { display: flex; flex: 1; align-items: center; justify-content: flex-end; gap: 1.1rem; }
  .nav-links { display: flex; align-items: center; gap: .1rem; list-style: none; }
  .nav-links > li > a, summary { display: flex; min-height: 44px; align-items: center; gap: .25rem; padding: .65rem .68rem; border-radius: 8px; color: #3d475a; cursor: pointer; font-size: .83rem; font-weight: 700; list-style: none; white-space: nowrap; }
  summary::-webkit-details-marker { display: none; }
  .nav-links > li > a:hover, summary:hover, .nav-links .active { background: var(--canvas); color: var(--violet-dark); }
  .nav-dropdown { position: relative; }
  .dropdown-panel { position: absolute; top: calc(100% + 12px); left: 50%; display: grid; width: min(680px, 90vw); grid-template-columns: repeat(2, 1fr); gap: .35rem; padding: .7rem; border: 1px solid var(--line); border-radius: 16px; background: white; box-shadow: var(--shadow-lg); transform: translateX(-50%); }
  .nav-dropdown:not([open]) .dropdown-panel { display: none; }
  .dropdown-panel a { display: grid; padding: .78rem .85rem; border-radius: 10px; }
  .dropdown-panel a:hover { background: var(--canvas); }
  .dropdown-panel strong { color: var(--ink); font-size: .82rem; }
  .dropdown-panel span { margin-top: .15rem; color: var(--muted); font-size: .7rem; }
  .nav-cta { min-height: 44px; padding: .65rem .92rem; font-size: .8rem; white-space: nowrap; }
  .menu-toggle { display: none; width: 46px; height: 46px; place-items: center; border: 0; border-radius: 9px; background: var(--canvas); cursor: pointer; }
  .menu-toggle span:not(.sr-only) { display: block; width: 22px; height: 2px; margin: 4px auto; border-radius: 2px; background: var(--ink); transition: transform var(--transition), opacity var(--transition); }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; }

  @media (max-width: 1040px) {
    .menu-toggle { display: block; margin-left: auto; }
    .nav-shell { position: absolute; top: 100%; right: 0; left: 0; display: none; height: calc(100dvh - 84px); overflow-y: auto; align-items: stretch; justify-content: flex-start; padding: 1rem 1.25rem 2rem; border-top: 1px solid var(--line); background: white; box-shadow: var(--shadow-lg); }
    .nav-shell.open { display: flex; flex-direction: column; }
    .nav-links { display: grid; align-items: stretch; }
    .nav-links > li > a, summary { justify-content: space-between; padding: .8rem; font-size: 1rem; }
    .dropdown-panel { position: static; width: 100%; grid-template-columns: 1fr; padding: .35rem 0 .35rem .8rem; border: 0; box-shadow: none; transform: none; }
    .nav-cta { width: 100%; margin-top: .75rem; }
    .menu-toggle[aria-expanded="true"] span:not(.sr-only):nth-of-type(2) { transform: translateY(6px) rotate(45deg); }
    .menu-toggle[aria-expanded="true"] span:not(.sr-only):nth-of-type(3) { opacity: 0; }
    .menu-toggle[aria-expanded="true"] span:not(.sr-only):nth-of-type(4) { transform: translateY(-6px) rotate(-45deg); }
  }
  @media (max-width: 520px) { .header-inner { min-height: 76px; } .nav-shell { height: calc(100dvh - 76px); } .logo img { width: 132px; } }
</style>

<script is:inline>
  const menuButton = document.getElementById('menu-toggle');
  const navShell = document.getElementById('primary-nav');
  const closeMenu = () => {
    menuButton?.setAttribute('aria-expanded', 'false');
    const label = menuButton?.querySelector('.sr-only');
    if (label) label.textContent = 'Open menu';
    navShell?.classList.remove('open');
    document.body.classList.remove('menu-open');
  };
  menuButton?.addEventListener('click', () => {
    const open = menuButton.getAttribute('aria-expanded') !== 'true';
    menuButton.setAttribute('aria-expanded', String(open));
    const label = menuButton.querySelector('.sr-only');
    if (label) label.textContent = open ? 'Close menu' : 'Open menu';
    navShell?.classList.toggle('open', open);
    document.body.classList.toggle('menu-open', open);
  });
  navShell?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
  document.addEventListener('keydown', event => { if (event.key === 'Escape') closeMenu(); });
  document.addEventListener('click', event => {
    document.querySelectorAll('.nav-dropdown[open]').forEach(dropdown => {
      if (!dropdown.contains(event.target)) dropdown.removeAttribute('open');
    });
  });
</script>
